---
// tambah-ruangan.astro — Halaman "Tambah Ruangan" (form)

const tagFasilitasTerpasang = ["LCD Besar", "Sound System", "AC", "Microphone"];

const activePage = "kelolaruangan";
import SidebarSuperAdmin from "../../../components/sidebarsuperadmin.astro";
---

<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tambah Ruangan — SI MAPAN</title>
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="../../../../src/styles/admin.css" />
  </head>
  <body>
    <div class="layout">
      <!-- ───────────── SIDEBAR ───────────── -->
      <SidebarSuperAdmin activePage="kelolaruangan" />
      <!-- ───────────── MAIN ───────────── -->
      <div class="main">
        <header class="topbar">
          <div class="topbar-title">
            <h1>Manajemen Ruangan</h1>
            <p>Kelola Ruangan</p>
          </div>
          <div class="topbar-actions">
            <button class="notif-btn" title="Notifikasi">
              <svg viewBox="0 0 20 20" fill="currentColor">
                <path
                  d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM8.5 16a1.5 1.5 0 003 0h-3z"
                ></path>
              </svg>
              <span class="notif-dot"></span>
            </button>
          </div>
        </header>

        <main class="content">
          <div class="page-card">
            <a href="/superadmin/kelolaruangan" class="back-link">
              <svg
                width="15"
                height="15"
                viewBox="0 0 20 20"
                fill="currentColor"
              >
                <path
                  fill-rule="evenodd"
                  d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 111.414 1.414L7.414 9H17a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z"
                  clip-rule="evenodd"></path>
              </svg>
              Kembali
            </a>

            <h2 class="page-title">Tambah Ruangan</h2>

            <div class="form-grid">
              <!-- ── Detail Ruangan ── -->
              <section class="bordered-card">
                <div class="section-header">
                  <svg
                    width="17"
                    height="17"
                    viewBox="0 0 20 20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                  >
                    <circle cx="4" cy="5" r="1.6"></circle>
                    <circle cx="16" cy="5" r="1.6"></circle>
                    <circle cx="4" cy="15" r="1.6"></circle>
                    <circle cx="16" cy="15" r="1.6"></circle>
                    <path d="M4 6.6V13.4M16 6.6V13.4M5.6 5H14.4M5.6 15H14.4"
                    ></path>
                  </svg>
                  Detail Ruangan
                </div>

                <div class="form-group">
                  <label for="namaRuangan">Nama Ruangan</label>
                  <input
                    type="text"
                    id="namaRuangan"
                    name="namaRuangan"
                    placeholder="e.g. Cocpit Room"
                  />
                </div>

                <div class="form-group">
                  <label for="kapasitas">Kapasitas</label>
                  <input
                    type="number"
                    id="kapasitas"
                    name="kapasitas"
                    value="25"
                  />
                  <p class="helper-text">Standard Safety Limit</p>
                </div>

                <div class="form-group">
                  <label for="lokasi">Lokasi</label>
                  <select id="lokasi" name="lokasi" class="select-highlight">
                    <option>Gedung 1</option>
                    <option>Gedung 2</option>
                  </select>
                </div>

                <div class="form-group">
                  <label for="statusRuangan">Status Ruangan</label>
                  <select id="statusRuangan" name="statusRuangan">
                    <option>Aktif</option>
                    <option>Nonaktif</option>
                    <option>Maintenance</option>
                  </select>
                </div>
              </section>

              <!-- ── Room Preview ── -->
              <section class="bordered-card">
                <div class="section-header">
                  <svg
                    width="17"
                    height="17"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      d="M4 7a2 2 0 012-2h.586a1 1 0 00.707-.293l1.414-1.414A1 1 0 019.414 3h1.172a1 1 0 01.707.293l1.414 1.414a1 1 0 00.707.293H14a2 2 0 012 2v7a2 2 0 01-2 2H6a2 2 0 01-2-2V7z"
                    ></path>
                    <circle cx="10" cy="9.5" r="2.5" fill="#ffffff"></circle>
                  </svg>
                  Room Preview
                </div>
                <input
                  type="file"
                  id="primary-file-input"
                  accept="image/*"
                  style="display: none;"
                />
                <input
                  type="file"
                  id="thumb-file-input"
                  accept="image/*"
                  style="display: none;"
                />

                <div
                  class="image-upload-box"
                  id="primary-upload-trigger"
                  style="cursor: pointer;"
                >
                  <div class="upload-overlay">
                    <svg
                      width="22"
                      height="22"
                      viewBox="0 0 20 20"
                      fill="#ffffff"
                    >
                      <path
                        d="M4 7a2 2 0 012-2h.586a1 1 0 00.707-.293l1.414-1.414A1 1 0 019.414 3h1.172a1 1 0 01.707.293l1.414 1.414a1 1 0 00.707.293H14a2 2 0 012 2v7a2 2 0 01-2 2H6a2 2 0 01-2-2V7z"
                      ></path>
                      <path
                        d="M14 5l1.2-1.2a.6.6 0 01.85 0L17 5"
                        stroke="#ffffff"
                        stroke-width="1.3"
                        fill="none"
                        stroke-linecap="round"></path>
                    </svg>
                    <p class="upload-title">Upload Primary Image</p>
                    <p class="upload-sub">HD recommended (Max 5MB)</p>
                  </div>
                </div>

                <div class="thumb-row">
                  <div
                    class="thumb-box thumb-add"
                    id="thumb-upload-trigger"
                    title="Tambah foto"
                    style="cursor: pointer;"
                  >
                    <svg
                      width="20"
                      height="20"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                    >
                      <path
                        d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z"
                      ></path>
                    </svg>
                  </div>

                  <div class="thumb-box thumb-locked" title="Terkunci">
                    <svg
                      width="18"
                      height="18"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M10 2a4 4 0 00-4 4v2H5a1 1 0 00-1 1v7a2 2 0 002 2h8a2 2 0 002-2V9a1 1 0 00-1-1h-1V6a4 4 0 00-4-4zm-2 6V6a2 2 0 114 0v2H8z"
                        clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <div class="thumb-box thumb-locked" title="Terkunci">
                    <svg
                      width="18"
                      height="18"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M10 2a4 4 0 00-4 4v2H5a1 1 0 00-1 1v7a2 2 0 002 2h8a2 2 0 002-2V9a1 1 0 00-1-1h-1V6a4 4 0 00-4-4zm-2 6V6a2 2 0 114 0v2H8z"
                        clip-rule="evenodd"></path>
                    </svg>
                  </div>
                </div>

                <div class="tag-fasilitas-header">
                  Tag Fasilitas
                  <button class="tag-add-btn" title="Tambah tag">
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                    >
                      <path
                        d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z"
                      ></path>
                    </svg>
                  </button>
                </div>

                    <div class="tag-list">
                      {
                        tagFasilitasTerpasang.map((tag) => (
                          <span class="tag-chip">{tag}</span>
                        ))
                      }
                    </div>
              </section>
            </div>

            <div class="submit-row">
              <button id="submit-btn" type="button" class="btn-submit-wide">Tambah Ruangan</button>
            </div>
          </div>
        </main>
      </div>
    </div>

    <style>
      /* ── Page wrapper card ── */
      .page-card {
        background: #fff;
        border: 1px solid #e8eaf0;
        border-radius: 14px;
        padding: 28px 32px 36px;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #29abe2;
        font-size: 13.5px;
        font-weight: 600;
        text-decoration: none;
        margin-bottom: 18px;
      }

      .back-link:hover {
        text-decoration: underline;
      }

      .page-title {
        font-size: 19px;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 22px;
      }

      /* ── Form grid ── */
      .form-grid {
        display: grid;
        grid-template-columns: 1.1fr 1fr;
        gap: 24px;
        margin-bottom: 28px;
      }

      .bordered-card {
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 24px 26px;
        background: #fff;
      }

      .section-header {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 15px;
        font-weight: 700;
        color: #29abe2;
        margin-bottom: 20px;
      }

      .form-group {
        margin-bottom: 20px;
      }

      .form-group:last-child {
        margin-bottom: 0;
      }

      .form-group label {
        display: block;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: #6b7280;
        margin-bottom: 8px;
      }

      .form-group input,
      .form-group select {
        width: 100%;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        padding: 11px 14px;
        font-family: "DM Sans", sans-serif;
        font-size: 13.5px;
        color: #1f2937;
        background: #fff;
      }

      .form-group input::placeholder {
        color: #9ca3af;
      }

      .form-group input:focus,
      .form-group select:focus {
        outline: none;
        border-color: #29abe2;
      }

      .select-highlight {
        border-color: #29abe2 !important;
      }

      .helper-text {
        font-size: 10.5px;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: #9ca3af;
        margin-top: 6px;
      }

      /* ── Room Preview ── */
      .image-upload-box {
        position: relative;
        height: 150px;
        border-radius: 10px;
        background: linear-gradient(120deg, #b9c4cd, #9aa7b2);
        overflow: hidden;
        margin-bottom: 14px;
      }

      .upload-overlay {
        position: absolute;
        inset: 0;
        background: rgba(60, 70, 80, 0.45);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 4px;
        color: #fff;
      }

      .upload-title {
        font-size: 13.5px;
        font-weight: 700;
      }

      .upload-sub {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.85);
      }

      .thumb-row {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
        margin-bottom: 22px;
      }

      .thumb-box {
        height: 76px;
        border-radius: 8px;
        background: #f1f4f7;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #9ca3af;
        cursor: pointer;
        transition: background 0.15s;
      }

      .thumb-add:hover {
        background: #e8f7fd;
        color: #29abe2;
      }

      .thumb-locked {
        cursor: not-allowed;
        opacity: 0.7;
      }

      .tag-fasilitas-header {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 700;
        color: #29abe2;
        margin-bottom: 12px;
      }

      .tag-add-btn {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        border: none;
        background: #e8f7fd;
        color: #29abe2;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
      }

      .tag-add-btn:hover {
        background: #d3eefa;
      }

      .tag-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .tag-chip {
        background: #e8f7fd;
        color: #1a7aa8;
        font-size: 12.5px;
        font-weight: 600;
        padding: 6px 14px;
        border-radius: 100px;
      }

      /* ── Submit ── */
      .submit-row {
        display: flex;
        justify-content: center;
      }

      .btn-submit-wide {
        background: #29abe2;
        color: #fff;
        border: none;
        border-radius: 9px;
        padding: 13px 38px;
        font-family: "DM Sans", sans-serif;
        font-size: 14.5px;
        font-weight: 700;
        cursor: pointer;
        transition:
          background 0.15s,
          transform 0.15s;
      }

      .btn-submit-wide:hover {
        background: #1f9bd1;
        transform: translateY(-1px);
      }

      @media (max-width: 860px) {
        .form-grid {
          grid-template-columns: 1fr;
        }
      }

      /* Notification */
      .notif {
        position: fixed;
        top: 20px;
        right: 20px;
        padding: 12px 16px;
        border-radius: 8px;
        color: #fff;
        font-weight: 700;
        display: none;
        z-index: 60;
      }
      .notif.success { background: #16a34a; }
      .notif.error { background: #dc2626; }
     </style>

    <script>
    document.addEventListener('DOMContentLoaded', function () {
      // 1. Logika untuk Upload Utama (Primary Image)
      const primaryTrigger = document.getElementById("primary-upload-trigger");
      const primaryInput = document.getElementById("primary-file-input");

      // Pastikan elemen ada sebelum menambahkan listener
      if (primaryTrigger && primaryInput instanceof HTMLInputElement) {
        primaryTrigger.addEventListener("click", function () {
          primaryInput.click(); // Memicu file explorer terbuka
        });

        primaryInput.addEventListener("change", function () {
          if (primaryInput.files && primaryInput.files[0]) {
            console.log("File utama yang dipilih:", primaryInput.files[0].name);
            // Di sini Anda bisa menambahkan logika pratinjau (preview) gambar atau upload ke server
          }
        });
      }

      // 2. Logika untuk Tambah Foto (Thumbnail)
      const thumbTrigger = document.getElementById("thumb-upload-trigger");
      const thumbInput = document.getElementById("thumb-file-input");

      if (thumbTrigger && thumbInput instanceof HTMLInputElement) {
        thumbTrigger.addEventListener("click", function () {
          thumbInput.click(); // Memicu file explorer terbuka
        });

        thumbInput.addEventListener("change", function () {
          if (thumbInput.files && thumbInput.files[0]) {
            console.log("File thumbnail yang dipilih:", thumbInput.files[0].name);
          }
        });
      }

      // --- Tag (Fasilitas) handling ---
      const tagListEl = document.querySelector('.tag-list');
      let tags = [];

      if (tagListEl) {
        tags = Array.from(tagListEl.querySelectorAll('.tag-chip')).map((el) => el.textContent.trim());
      }

      function renderTags() {
        if (!tagListEl) return;
        tagListEl.innerHTML = '';
        tags.forEach((t) => {
          const span = document.createElement('span');
          span.className = 'tag-chip';
          span.textContent = t;
          tagListEl.appendChild(span);
        });
      }

      // initialise
      renderTags();

      const tagAddBtn = document.querySelector('.tag-add-btn');
      if (tagAddBtn) {
        tagAddBtn.addEventListener('click', function () {
          const name = prompt('Masukkan nama fasilitas baru:');
          if (name && name.trim()) {
            tags.push(name.trim());
            renderTags();
          }
        });
      }

      // --- Form submit / validation / notification / redirect ---
      const submitBtn = document.getElementById('submit-btn');
      function showNotif(message, type = 'success') {
        let n = document.getElementById('notif');
        if (!n) {
          n = document.createElement('div');
          n.id = 'notif';
          n.className = 'notif';
          document.body.appendChild(n);
        }
        n.textContent = message;
        n.className = 'notif ' + (type === 'error' ? 'error' : 'success');
        n.style.display = 'block';
        setTimeout(() => { n.style.display = 'none'; }, 2000);
      }

      if (submitBtn) {
        submitBtn.addEventListener('click', function (e) {
          e.preventDefault();
          const namaEl = document.getElementById('namaRuangan');
          const kapasitasEl = document.getElementById('kapasitas');
          const lokasiEl = document.getElementById('lokasi');
          const statusEl = document.getElementById('statusRuangan');

          const nama = namaEl ? namaEl.value.trim() : '';
          const kapasitas = kapasitasEl ? kapasitasEl.value.trim() : '';
          const lokasi = lokasiEl ? lokasiEl.value.trim() : '';
          const status = statusEl ? statusEl.value.trim() : '';

          // simple validation
          if (!nama || !kapasitas || !lokasi || !status) {
            showNotif('Data belum lengkap — isi semua field.', 'error');
            return;
          }

          // TODO: replace with real submit to server
          console.log('Submit payload:', { nama, kapasitas, lokasi, status, fasilitas: tags });
          showNotif('Ruangan berhasil ditambahkan', 'success');

          setTimeout(() => {
            window.location.href = '/superadmin/kelolaruangan';
          }, 900);
        });
      }
    });
    </script>
  </body>
</html>
