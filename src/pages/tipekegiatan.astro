---
// SI MAPAN - Ajukan Penggunaan Ruangan
// Pilih Tipe Kegiatan
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SI MAPAN — Ajukan Penggunaan Ruangan</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --sidebar-bg: #1e2433;
        --sidebar-w: 200px;
        --sidebar-text: #a8b3c8;
        --sidebar-active-bg: #2d3650;
        --sidebar-active-text: #ffffff;
        --sidebar-label: #5a6680;
        --accent-red: #c0392b;

        --page-bg: #f4f6f9;
        --topbar-bg: #ffffff;
        --topbar-border: #e8eaf0;

        --card-bg: #ffffff;
        --card-shadow: 0 1px 4px rgba(0,0,0,0.08);
        --card-radius: 12px;

        --text-1: #111827;
        --text-2: #4b5563;
        --text-3: #9ca3af;

        --warning-bg: #fffbeb;
        --warning-border: #fde68a;
        --warning-text: #78350f;
        --warning-icon: #f59e0b;

        --tipe-border: #e5e7eb;
        --tipe-selected-border: #3b82f6;
        --tipe-selected-bg: #eff6ff;
        --tipe-icon: #3b82f6;
        --tipe-hover-bg: #f9fafb;

        --link: #3b82f6;
      }

      html, body { height: 100%; font-family: 'DM Sans', sans-serif; background: var(--page-bg); }

      /* ── Layout ── */
      .layout { display: flex; min-height: 100vh; }

      /* ── Sidebar ── */
      .sidebar {
        width: var(--sidebar-w);
        min-height: 100vh;
        background: var(--sidebar-bg);
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        position: fixed;
        top: 0; left: 0; bottom: 0;
        z-index: 100;
      }

      .sidebar-logo {
        padding: 20px 18px 18px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 2px;
      }

      .logo-badge {
        display: inline-flex;
        align-items: center;
        border: 2px solid var(--accent-red);
        border-radius: 40px;
        padding: 3px 12px;
        margin-bottom: 3px;
      }

      .logo-badge span {
        font-size: 15px;
        font-weight: 700;
        letter-spacing: 0.05em;
        color: var(--accent-red);
      }

      .logo-tagline {
        font-size: 9.5px;
        color: #7a8599;
        letter-spacing: 0.02em;
        line-height: 1.4;
      }

      .logo-tagline strong { color: var(--accent-red); font-weight: 600; }

      .nav-section { padding: 20px 0 8px; }

      .nav-section-label {
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--sidebar-label);
        padding: 0 18px 8px;
      }

      .nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 18px;
        color: var(--sidebar-text);
        font-size: 13px;
        font-weight: 400;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.15s, color 0.15s;
        border-left: 3px solid transparent;
        margin: 1px 0;
      }

      .nav-item:hover { background: rgba(255,255,255,0.05); color: #fff; }

      .nav-item.active {
        background: var(--sidebar-active-bg);
        color: var(--sidebar-active-text);
        border-left-color: var(--link);
        font-weight: 500;
      }

      .nav-item svg { flex-shrink: 0; opacity: 0.7; }
      .nav-item.active svg { opacity: 1; }

      .sidebar-footer {
        margin-top: auto;
        padding: 14px 16px;
        border-top: 1px solid rgba(255,255,255,0.06);
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .avatar {
        width: 32px; height: 32px;
        border-radius: 50%;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0;
      }

      .user-info { flex: 1; min-width: 0; }

      .user-name {
        font-size: 12.5px;
        font-weight: 600;
        color: #e2e8f0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .user-role {
        font-size: 10.5px;
        color: var(--sidebar-label);
        white-space: nowrap;
      }

      .logout-btn {
        background: none;
        border: none;
        cursor: pointer;
        color: var(--sidebar-label);
        padding: 4px;
        border-radius: 4px;
        transition: color 0.15s;
        display: flex;
        align-items: center;
      }

      .logout-btn:hover { color: #ef4444; }

      /* ── Main ── */
      .main {
        margin-left: var(--sidebar-w);
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      /* Topbar */
      .topbar {
        background: var(--topbar-bg);
        border-bottom: 1px solid var(--topbar-border);
        padding: 0 28px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 50;
      }

      .topbar-title h1 {
        font-size: 15px;
        font-weight: 600;
        color: var(--text-1);
      }

      .topbar-title p {
        font-size: 11.5px;
        color: var(--text-3);
        margin-top: 1px;
      }

      .notif-btn {
        position: relative;
        background: none;
        border: none;
        cursor: pointer;
        padding: 6px;
        color: var(--text-2);
        border-radius: 8px;
        transition: background 0.15s;
        display: flex;
        align-items: center;
      }

      .notif-btn:hover { background: #f3f4f6; }

      .notif-dot {
        position: absolute;
        top: 5px; right: 5px;
        width: 8px; height: 8px;
        border-radius: 50%;
        background: #ef4444;
        border: 2px solid #fff;
      }

      /* ── Content ── */
      .content {
        padding: 24px 28px;
        flex: 1;
        animation: pageIn 0.45s cubic-bezier(0.22,1,0.36,1) both;
      }

      @keyframes pageIn {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      /* ── Card wrapper ── */
      .section-card {
        background: var(--card-bg);
        border-radius: var(--card-radius);
        box-shadow: var(--card-shadow);
        padding: 24px 24px 28px;
      }

      .section-title {
        font-size: 15px;
        font-weight: 600;
        color: var(--text-1);
        margin-bottom: 16px;
      }

      /* ── Warning banner ── */
      .warning-banner {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        background: var(--warning-bg);
        border: 1.5px solid var(--warning-border);
        border-radius: 8px;
        padding: 12px 16px;
        margin-bottom: 22px;
      }

      .warning-icon { flex-shrink: 0; margin-top: 1px; color: var(--warning-icon); }

      .warning-text {
        font-size: 13px;
        color: var(--warning-text);
        line-height: 1.5;
      }

      .warning-text strong { font-weight: 700; }

      /* ── Tipe cards ── */
      .tipe-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
      }

      .tipe-card {
        border: 2px solid var(--tipe-border);
        border-radius: 10px;
        padding: 32px 20px 28px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        background: #fff;
        transition: border-color 0.2s, background 0.2s, box-shadow 0.2s, transform 0.15s;
        user-select: none;
        text-align: center;
      }

      .tipe-card:hover {
        border-color: #93c5fd;
        background: var(--tipe-hover-bg);
        box-shadow: 0 2px 12px rgba(59,130,246,0.1);
        transform: translateY(-2px);
      }

      .tipe-card.selected {
        border-color: var(--tipe-selected-border);
        background: var(--tipe-selected-bg);
        box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
      }

      .tipe-icon {
        width: 52px;
        height: 52px;
        color: var(--tipe-icon);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .tipe-icon svg { width: 100%; height: 100%; }

      .tipe-label {
        font-size: 15px;
        font-weight: 700;
        color: var(--text-1);
        letter-spacing: 0.01em;
      }

      .tipe-desc {
        font-size: 12.5px;
        color: var(--text-3);
        line-height: 1.4;
        max-width: 180px;
      }

      /* Next button (appears after selection) */
      .next-wrap {
        margin-top: 24px;
        display: flex;
        justify-content: flex-end;
        opacity: 0;
        transform: translateY(8px);
        transition: opacity 0.3s, transform 0.3s;
        pointer-events: none;
      }

      .next-wrap.visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }

      .btn-next {
        background: #3b82f6;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 11px 28px;
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
      }

      .btn-next:hover {
        background: #2563eb;
        box-shadow: 0 4px 14px rgba(59,130,246,0.35);
        transform: translateY(-1px);
      }

      /* ── Responsive ── */
      @media (max-width: 620px) {
        .tipe-grid { grid-template-columns: 1fr; }
        .content { padding: 16px; }
      }
    </style>
  </head>

  <body>
    <div class="layout">

      <!-- ── Sidebar ── -->
      <aside class="sidebar">
        <div class="sidebar-logo">
          <div class="logo-badge"><span>SI MAPAN</span></div>
          <p class="logo-tagline">Sistem ru<strong>MAh</strong> tangga<br>dan kearsi<strong>PAN</strong></p>
        </div>

        <nav class="nav-section">
          <p class="nav-section-label">Penggunaan Ruangan</p>

          <a href="/dashboard" class="nav-item">
            <svg width="15" height="15" viewBox="0 0 20 20" fill="currentColor"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h4a1 1 0 001-1v-3h2v3a1 1 0 001 1h4a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/></svg>
            Beranda
          </a>

          <a href="#" class="nav-item active">
            <svg width="15" height="15" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>
            Ajukan Penggunaan
          </a>

          <a href="#" class="nav-item">
            <svg width="15" height="15" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg>
            Riwayat Pengajuan
          </a>
        </nav>

        <div class="sidebar-footer">
          <div class="avatar">AP</div>
          <div class="user-info">
            <p class="user-name">Andi Prasetyo</p>
            <p class="user-role">Karyawan</p>
          </div>
          <button class="logout-btn" title="Keluar">
            <svg width="15" height="15" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z" clip-rule="evenodd"/>
            </svg>
          </button>
        </div>
      </aside>

      <!-- ── Main ── -->
      <div class="main">

        <!-- Topbar -->
        <header class="topbar">
          <div class="topbar-title">
            <h1>Ajukan Penggunaan Ruangan</h1>
            <p>Ikuti langkah berikut</p>
          </div>
          <button class="notif-btn" title="Notifikasi">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
              <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zm0 16a2 2 0 01-2-2h4a2 2 0 01-2 2z"/>
            </svg>
            <span class="notif-dot"></span>
          </button>
        </header>

        <!-- Content -->
        <main class="content">
          <div class="section-card">
            <h2 class="section-title">Pilih Tipe Kegiatan</h2>

            <!-- Warning banner -->
            <div class="warning-banner">
              <span class="warning-icon">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                </svg>
              </span>
              <p class="warning-text">
                Batas waktu pengajuan adalah <strong>H–1 sebelum kegiatan</strong>. Pastikan pengajuan dilakukan tepat waktu.
              </p>
            </div>

            <!-- Tipe cards -->
            <div class="tipe-grid" id="tipeGrid">

              <!-- Full Offline -->
              <div class="tipe-card selected" data-tipe="offline" role="button" tabindex="0" aria-pressed="true">
                <div class="tipe-icon">
                  <!-- people/group icon -->
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                    <path d="M16 3.13a4 4 0 010 7.75"/>
                  </svg>
                </div>
                <p class="tipe-label">Full Offline</p>
                <p class="tipe-desc">Kegiatan tatap muka di ruang yang dipilih</p>
              </div>

              <!-- Hybrid -->
              <div class="tipe-card" data-tipe="hybrid" role="button" tabindex="0" aria-pressed="false">
                <div class="tipe-icon">
                  <!-- phone/video call icon -->
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8 19.79 19.79 0 01.01 1.17 2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.9v2.02z"/>
                    <polyline points="16 2 20 6 16 10"/>
                    <line x1="20" y1="6" x2="14" y2="6"/>
                  </svg>
                </div>
                <p class="tipe-label">Hybrid</p>
                <p class="tipe-desc">Kombinasi tatap muka dan virtual/online</p>
              </div>

            </div>

            <!-- Next button -->
            <div class="next-wrap visible" id="nextWrap">
              <button class="btn-next" id="nextBtn">Lanjutkan →</button>
            </div>
          </div>
        </main>
      </div>
    </div>

    <script>
      const cards    = document.querySelectorAll('.tipe-card') as NodeListOf<HTMLElement>;
      const nextWrap = document.getElementById('nextWrap') as HTMLDivElement;
      let selected: string | null = 'offline'; // default selection matches UI

      function selectCard(card: HTMLElement) {
        cards.forEach(c => {
          c.classList.remove('selected');
          c.setAttribute('aria-pressed', 'false');
        });
        card.classList.add('selected');
        card.setAttribute('aria-pressed', 'true');
        selected = card.dataset.tipe ?? null;
        nextWrap.classList.add('visible');
      }

      cards.forEach(card => {
        card.addEventListener('click', () => selectCard(card));
        card.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            selectCard(card);
          }
        });
      });

      document.getElementById('nextBtn')?.addEventListener('click', () => {
        if (!selected) return;
        console.log('Tipe dipilih:', selected);
        // TODO: navigate to next step with selected type
        // window.location.href = `/ajukan/detail?tipe=${selected}`;
      });
    </script>
  </body>
</html>