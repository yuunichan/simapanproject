---
// src/pages/user/ajukan/konfirmasi.astro
// Step 3 — Konfirmasi Pengajuan

import Sidebar from '../../../components/sidebar_user.astro';
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SI MAPAN — Konfirmasi Pengajuan</title>
</head>
<body>
<div class="layout">

  <Sidebar activePage="ajukan" />

  <main class="main-content">

    <!-- Top Header -->
    <header class="topbar">
      <div>
        <h1 class="topbar-title">Ajukan Penggunaan Ruangan</h1>
        <p class="topbar-sub">Ikuti langkah berikut</p>
      </div>
      <button class="notif-btn" aria-label="Notifikasi">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        <span class="notif-dot"></span>
      </button>
    </header>

    <div class="content-wrap">

      <!-- Stepper -->
      <div class="stepper">
        <div class="step">
          <div class="step-circle done">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <span class="step-label">Mode</span>
        </div>
        <div class="step-line filled"></div>
        <div class="step">
          <div class="step-circle done">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <span class="step-label">Ruangan &amp; Jadwal</span>
        </div>
        <div class="step-line filled"></div>
        <div class="step">
          <div class="step-circle current">3</div>
          <span class="step-label bold">Konfirmasi</span>
        </div>
      </div>

      <!-- Confirmation Card -->
      <div class="confirm-card">
        <div class="confirm-header">
          <h2 class="confirm-title">Konfirmasi Pengajuan</h2>
          <p class="confirm-sub">Periksa kembali detail pengajuan Anda sebelum dikirim.</p>
        </div>

        <div class="detail-table">
          <div class="detail-row">
            <span class="detail-label">GEDUNG</span>
            <span class="detail-value" id="valGedung">Gedung 1</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">RUANGAN</span>
            <span class="detail-value" id="valRuangan">Ruang Mawar</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">MODE</span>
            <span class="detail-value mode-badge" id="valMode">Full Offline</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">TANGGAL</span>
            <span class="detail-value" id="valTanggal">15 Maret 2026</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">WAKTU</span>
            <span class="detail-value" id="valWaktu">09:00 – 12:00 WIB</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">JENIS</span>
            <span class="detail-value" id="valJenis">Rapat Internal</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">PESERTA</span>
            <span class="detail-value" id="valPeserta">25 orang</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">UNIT KERJA</span>
            <span class="detail-value" id="valUnit">Div. Teknologi Informasi</span>
          </div>
        </div>

        <!-- Warning notice -->
        <div class="notice">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
          <span>Pengajuan akan diproses Admin. Notifikasi akan dikirim ke email Anda.</span>
        </div>

        <!-- Actions -->
        <div class="action-row">
          <button class="btn-back" onclick="history.back()">← Kembali</button>
          <button class="btn-submit" id="btnKirim">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            Kirim Pengajuan
          </button>
        </div>
      </div>

    </div><!-- /content-wrap -->
  </main>
</div>

<!-- ── SUCCESS POPUP ── -->
<div class="overlay" id="overlay" aria-hidden="true">
  <div class="popup" id="popup" role="dialog" aria-modal="true" aria-labelledby="popupTitle">

    <!-- Icon -->
    <div class="popup-icon-wrap">
      <div class="popup-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
          stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
    </div>

    <h3 class="popup-title" id="popupTitle">Pengajuan Terkirim!</h3>
    <p class="popup-sub">Nomor tiket pengajuan Anda:</p>

    <!-- Ticket number -->
    <div class="ticket-box">
      <span class="ticket-num" id="ticketNum">R/013/03/2026</span>
      <button class="copy-btn" id="copyBtn" title="Salin nomor tiket">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
      </button>
    </div>

    <p class="popup-info">Admin akan memproses pengajuan Anda. Notifikasi akan dikirim ke email.</p>

    <div class="popup-actions">
      <button class="popup-btn-secondary" id="btnAjukanLagi">Ajukan Lagi</button>
      <button class="popup-btn-primary" id="btnLihatRiwayat">Lihat Riwayat</button>
    </div>
  </div>
</div>

<script>
  // ── Read URL params & populate detail ──
  const params   = new URLSearchParams(window.location.search);
  const roomMap: Record<string, { name: string; gedung: string }> = {
    aula:    { name: 'Ruang Aula',    gedung: 'Gedung 1' },
    mawar:   { name: 'Ruang Mawar',   gedung: 'Gedung 1' },
    control: { name: 'Control Room',  gedung: 'Gedung 1' },
    data:    { name: 'Ruang Data',    gedung: 'Gedung 1' },
    kokpit:  { name: 'Ruang Kokpit',  gedung: 'Gedung 1' },
  };

  const roomId  = params.get('room') ?? 'mawar';
  const room    = roomMap[roomId] ?? { name: roomId, gedung: 'Gedung 1' };
  const tgl     = params.get('tgl')  ?? '';
  const jam     = params.get('jam')  ?? '';
  const role    = params.get('role') ?? 'Full Offline';

  // Format tanggal
  function formatTanggal(raw: string) {
    if (!raw) return '—';
    const [y, m, d] = raw.split('-');
    const bulan = ['','Januari','Februari','Maret','April','Mei','Juni',
                   'Juli','Agustus','September','Oktober','November','Desember'];
    return `${parseInt(d)} ${bulan[parseInt(m)]} ${y}`;
  }

  // Format waktu dari slot jam (misal "09:00,10:00,11:00")
  function formatWaktu(slots: string) {
    if (!slots) return '—';
    const arr = slots.split(',').sort();
    const first = arr[0];
    const lastH = parseInt(arr[arr.length - 1].split(':')[0]) + 1;
    return `${first} – ${String(lastH).padStart(2,'0')}:00 WIB`;
  }

  // Inject values
  const set = (id: string, val: string) => {
    const el = document.getElementById(id);
    if (el) el.textContent = val;
  };

  set('valGedung',  room.gedung);
  set('valRuangan', room.name);
  set('valMode',    role || 'Full Offline');
  set('valTanggal', formatTanggal(tgl));
  set('valWaktu',   formatWaktu(jam));
  // jenis, peserta, unit: idealnya dari step 1 (disimpan di sessionStorage)
  set('valJenis',   sessionStorage.getItem('jenis')   ?? 'Rapat Internal');
  set('valPeserta', sessionStorage.getItem('peserta') ?? '25 orang');
  set('valUnit',    sessionStorage.getItem('unit')    ?? 'Div. Teknologi Informasi');

  // ── Generate ticket number ──
  function genTicket() {
    const now  = new Date();
    const mm   = String(now.getMonth() + 1).padStart(2, '0');
    const yy   = now.getFullYear();
    const seq  = String(Math.floor(Math.random() * 900) + 100);
    return `R/${seq}/${mm}/${yy}`;
  }

  // ── Show popup ──
  const overlay = document.getElementById('overlay')!;
  const popup   = document.getElementById('popup')!;

  function openPopup() {
    const ticket = genTicket();
    document.getElementById('ticketNum')!.textContent = ticket;
    overlay.classList.add('visible');
    popup.classList.add('visible');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closePopup() {
    overlay.classList.remove('visible');
    popup.classList.remove('visible');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // Submit button
  document.getElementById('btnKirim')!.addEventListener('click', () => {
    openPopup();
  });

  // Copy ticket
  document.getElementById('copyBtn')!.addEventListener('click', () => {
    const num = document.getElementById('ticketNum')!.textContent ?? '';
    navigator.clipboard.writeText(num).then(() => {
      const btn = document.getElementById('copyBtn')!;
      btn.classList.add('copied');
      setTimeout(() => btn.classList.remove('copied'), 1800);
    });
  });

  // Close on overlay click
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closePopup();
  });

  // Popup action buttons
  document.getElementById('btnLihatRiwayat')!.addEventListener('click', () => {
    window.location.href = '/user/riwayat';
  });
  document.getElementById('btnAjukanLagi')!.addEventListener('click', () => {
    window.location.href = '/user/ajukan-ruangan';
  });

  // ESC to close
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closePopup();
  });
</script>

<style>
  /* ── Layout ── */
  .layout       { display: flex; min-height: 100vh; }
  .main-content { margin-left: var(--sidebar-w, 200px); flex: 1; display: flex; flex-direction: column; background: var(--page-bg, #f4f6f9); }

  /* ── Topbar ── */
  .topbar       { background: var(--topbar-bg,#fff); border-bottom: 1px solid #e8ecf0; padding: 14px 32px; display: flex; align-items: center; justify-content: space-between; }
  .topbar-title { font-size: 18px; font-weight: 800; color: #1e293b; }
  .topbar-sub   { font-size: 12px; color: #94a3b8; margin-top: 2px; }
  .notif-btn    { background: none; border: none; cursor: pointer; position: relative; padding: 6px; border-radius: 8px; color: #64748b; display: flex; }
  .notif-btn svg{ width: 22px; height: 22px; }
  .notif-dot    { position: absolute; top: 4px; right: 4px; width: 8px; height: 8px; background: #e91e8c; border-radius: 50%; border: 2px solid #fff; }

  /* ── Content ── */
  .content-wrap { padding: 24px 32px; flex: 1; display: flex; flex-direction: column; gap: 20px; }

  /* ── Stepper ── */
  .stepper      { display: flex; align-items: center; background: #fff; border-radius: 12px; padding: 16px 28px; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
  .step         { display: flex; align-items: center; gap: 10px; white-space: nowrap; }
  .step-circle  { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 800; background: #e2e8f0; color: #94a3b8; flex-shrink: 0; }
  .step-circle.done    { background: #22c55e; color: #fff; }
  .step-circle.done svg{ width: 14px; height: 14px; }
  .step-circle.current { background: #0ea5e9; color: #fff; }
  .step-label   { font-size: 13.5px; font-weight: 600; color: #94a3b8; }
  .step-label.bold { color: #1e293b; font-weight: 800; }
  .step-line    { flex: 1; height: 2px; background: #e2e8f0; margin: 0 12px; }
  .step-line.filled { background: #22c55e; }

  /* ── Confirm Card ── */
  .confirm-card { background: #fff; border-radius: 14px; box-shadow: 0 1px 3px rgba(0,0,0,.06); overflow: hidden; }

  .confirm-header { padding: 24px 28px 0; }
  .confirm-title  { font-size: 17px; font-weight: 800; color: #1e293b; }
  .confirm-sub    { font-size: 13px; color: #94a3b8; margin-top: 4px; }

  /* Detail table */
  .detail-table { padding: 20px 28px; display: flex; flex-direction: column; gap: 0; border-bottom: 1px solid #f1f5f9; }
  .detail-row   { display: flex; align-items: baseline; padding: 11px 0; border-bottom: 1px solid #f8fafc; gap: 20px; }
  .detail-row:last-child { border-bottom: none; }
  .detail-label { min-width: 110px; font-size: 11px; font-weight: 800; color: #94a3b8; letter-spacing: .06em; text-transform: uppercase; flex-shrink: 0; }
  .detail-value { font-size: 14px; font-weight: 600; color: #1e293b; }
  .mode-badge   { color: #0ea5e9; font-weight: 700; }

  /* Notice */
  .notice { display: flex; align-items: center; gap: 10px; margin: 0 28px; padding: 13px 16px; background: #fffbeb; border: 1px solid #fde68a; border-radius: 8px; font-size: 13px; color: #92400e; font-weight: 600; }
  .notice svg { width: 18px; height: 18px; color: #f59e0b; flex-shrink: 0; }

  /* Actions */
  .action-row  { display: flex; justify-content: space-between; align-items: center; padding: 20px 28px; }
  .btn-back    { background: none; border: 1.5px solid #e2e8f0; font-size: 13.5px; font-weight: 700; color: #64748b; padding: 10px 22px; border-radius: 8px; cursor: pointer; transition: all .15s; }
  .btn-back:hover { background: #f8fafc; }
  .btn-submit  { display: flex; align-items: center; gap: 8px; background: #0ea5e9; border: none; font-size: 13.5px; font-weight: 800; color: #fff; padding: 10px 26px; border-radius: 8px; cursor: pointer; transition: background .15s; }
  .btn-submit svg { width: 16px; height: 16px; }
  .btn-submit:hover { background: #0284c7; }
  .btn-submit:active { background: #0369a1; transform: scale(.98); }

  /* ── Overlay ── */
  .overlay { position: fixed; inset: 0; background: rgba(15,23,42,.45); backdrop-filter: blur(3px); display: flex; align-items: center; justify-content: center; z-index: 100; opacity: 0; pointer-events: none; transition: opacity .25s ease; }
  .overlay.visible { opacity: 1; pointer-events: auto; }

  /* ── Popup ── */
  .popup { background: #fff; border-radius: 20px; padding: 36px 32px 28px; width: 100%; max-width: 420px; text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,.18); transform: scale(.92) translateY(12px); opacity: 0; transition: transform .3s cubic-bezier(.34,1.56,.64,1), opacity .25s ease; }
  .popup.visible { transform: scale(1) translateY(0); opacity: 1; }

  /* Popup icon */
  .popup-icon-wrap { display: flex; justify-content: center; margin-bottom: 18px; }
  .popup-icon { width: 72px; height: 72px; border-radius: 50%; background: #dcfce7; display: flex; align-items: center; justify-content: center; border: 4px solid #bbf7d0; }
  .popup-icon svg { width: 30px; height: 30px; color: #16a34a; stroke-width: 3; }

  .popup-title { font-size: 20px; font-weight: 800; color: #1e293b; margin: 0 0 4px; }
  .popup-sub   { font-size: 13px; color: #64748b; margin: 0 0 14px; }

  /* Ticket box */
  .ticket-box { display: flex; align-items: center; justify-content: center; gap: 10px; background: #f0f9ff; border: 1.5px solid #bae6fd; border-radius: 10px; padding: 14px 20px; margin-bottom: 14px; }
  .ticket-num { font-size: 22px; font-weight: 900; color: #0369a1; letter-spacing: .04em; font-family: 'Courier New', monospace; }
  .copy-btn   { background: none; border: 1px solid #bae6fd; border-radius: 6px; padding: 5px 8px; cursor: pointer; color: #0ea5e9; display: flex; align-items: center; transition: all .15s; }
  .copy-btn svg { width: 14px; height: 14px; }
  .copy-btn:hover { background: #e0f2fe; }
  .copy-btn.copied { background: #dcfce7; border-color: #86efac; color: #16a34a; }

  .popup-info { font-size: 12.5px; color: #94a3b8; line-height: 1.6; margin: 0 0 24px; }

  .popup-actions { display: flex; gap: 10px; }
  .popup-btn-secondary { flex: 1; background: none; border: 1.5px solid #e2e8f0; font-size: 13.5px; font-weight: 700; color: #64748b; padding: 11px; border-radius: 9px; cursor: pointer; transition: all .15s; }
  .popup-btn-secondary:hover { background: #f8fafc; }
  .popup-btn-primary { flex: 1; background: #0ea5e9; border: none; font-size: 13.5px; font-weight: 800; color: #fff; padding: 11px; border-radius: 9px; cursor: pointer; transition: background .15s; }
  .popup-btn-primary:hover { background: #0284c7; }
</style>

</body>
</html>