---
// SI MAPAN - Ajukan Penggunaan Ruangan (Single Page: Mode + Ruangan & Jadwal)

import Sidebar from "../../components/sidebar_user.astro";

// Data ruangan (idealnya dari API/database)
const rooms = [
  {
    id: "aula",
    name: "Ruang Aula",
    floor: "Lantai 2",
    gedung: "Gedung 1",
    capacity: "100–200",
    status: "busy",
    fasilitas: ["Panggung", "LCD Besar", "Sound System", "AC", "Microphone"],
    photos: ["/images/aula-1.jpg", "/images/aula-2.jpg", "/images/aula-3.jpg"],
  },
  {
    id: "mawar",
    name: "Ruang Mawar",
    floor: "Lantai 1",
    gedung: "Gedung 1",
    capacity: "10–30",
    status: "available",
    fasilitas: ["LCD", "AC", "Whiteboard"],
    photos: ["/images/mawar-1.jpg"],
  },
  {
    id: "control",
    name: "Control Room",
    floor: "Lantai 1",
    gedung: "Gedung 1",
    capacity: "0–10",
    status: "available",
    fasilitas: ["Monitor", "AC"],
    photos: ["/images/control-1.jpg"],
  },
  {
    id: "data",
    name: "Ruang Data",
    floor: "Lantai 1",
    gedung: "Gedung 1",
    capacity: "5–20",
    status: "available",
    fasilitas: ["AC", "Proyektor"],
    photos: ["/images/data-1.jpg"],
  },
  {
    id: "kokpit",
    name: "Ruang Kokpit",
    floor: "Lantai 3",
    gedung: "Gedung 1",
    capacity: "5–15",
    status: "available",
    fasilitas: ["AC", "TV", "Whiteboard"],
    photos: ["/images/kokpit-1.jpg"],
  },
];

// Hari & jam slot
const jamSlots = [
  "07:00",
  "08:00",
  "09:00",
  "10:00",
  "11:00",
  "12:00",
  "13:00",
  "14:00",
  "15:00",
  "16:00",
  "17:00",
  "18:00",
];

// Status jam contoh (busy/sebagian/available) — nanti dari API
const jamStatus: Record<string, "sebagian" | "available"> = {
  "07:00": "available",
  "08:00": "available",
  "09:00": "available",
  "10:00": "sebagian",
  "11:00": "available",
  "12:00": "available",
  "13:00": "sebagian",
  "14:00": "available",
  "15:00": "available",
  "16:00": "available",
  "17:00": "available",
  "18:00": "available",
};

const kalenderStatus: Record<string, "available" | "sebagian" | "penuh"> = {
  "2026-04-20": "available",
  "2026-04-21": "available",
  "2026-04-22": "sebagian",
  "2026-04-23": "available",
  "2026-04-24": "available",
  "2026-04-25": "available",
  "2026-04-26": "available",
  "2026-04-27": "available",
  "2026-04-28": "available",
  "2026-04-29": "available",
  "2026-04-30": "available",
  "2026-05-01": "available",
  "2026-05-02": "sebagian",
  "2026-05-03": "penuh",
  "2026-05-04": "available",
  "2026-05-05": "available",
  "2026-05-06": "sebagian",
  "2026-05-07": "available",
  "2026-05-08": "available",
  "2026-05-09": "available",
  "2026-05-10": "available",
};

function getMonthRange(statusMap: Record<string, string>) {
  const dates = Object.keys(statusMap).sort();
  if (dates.length === 0) {
    return [];
  }

  const start = new Date(dates[0]);
  const end = new Date(dates[dates.length - 1]);
  const months: string[] = [];
  let year = start.getFullYear();
  let month = start.getMonth();

  while (year < end.getFullYear() || month <= end.getMonth()) {
    months.push(`${year}-${String(month + 1).padStart(2, "0")}`);
    month += 1;
    if (month > 11) {
      month = 0;
      year += 1;
    }
  }

  return months;
}

function getDatesForMonth(monthKey: string) {
  const [year, month] = monthKey.split("-").map(Number);
  const daysInMonth = new Date(year, month, 0).getDate();
  return Array.from(
    { length: daysInMonth },
    (_, index) =>
      `${year}-${String(month).padStart(2, "0")}-${String(index + 1).padStart(2, "0")}`,
  );
}

const kalenderMonths = getMonthRange(kalenderStatus);
const kalenderDates = kalenderMonths.flatMap(getDatesForMonth);
const dayNames = ["MIN", "SEN", "SEL", "RAB", "KAM", "JUM", "SAB"];

function formatDayLabel(dateString: string) {
  const date = new Date(dateString);
  return dayNames[date.getDay()];
}

function formatMonthLabel(monthKey: string) {
  const [year, month] = monthKey.split("-");
  const date = new Date(`${year}-${month}-01`);
  return date.toLocaleString("id-ID", { month: "long", year: "numeric" });
}
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SI MAPAN - Ajukan Penggunaan Ruangan</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="../../src/styles/admin.css" />
  </head>
  <body>
    <div class="layout">
      <!-- Sidebar -->
      <Sidebar activePage="ajukan" />

      <!-- Main Content -->
      <main class="main">
        <!-- Top Header -->
        <header class="topbar">
          <div class="topbar-title">
            <h1 class="page-title">Ajukan Penggunaan Ruangan</h1>
            <p class="page-subtitle">Ikuti langkah berikut</p>
          </div>
          <div class="header-actions">
            <button class="notif-btn">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
              </svg>
              <span class="notif-dot"></span>
            </button>
          </div>
        </header>

        <!-- Content Area -->
        <div class="content">
          <div class="hero">
            <div class="hero-text">
              <div class="hero-ajukan">
                <div class="layout-ajukan">
                  <img
                    class="img-ajukan"
                    src="../../../src/assets/ajukan.png"
                    alt="Ajukan"
                  />
                </div>
                <div class="hero-text">
                  <h5 class="hero-name-aju">Ajukan Penggunaan Ruangan</h5>
                  <p class="hero-division">
                    Pilih ruangan, tanggal, jam, dan lengkapi detail kegiatan
                    Anda
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- ============ STEP 1: PILIH MODE ============ -->
          <div class="card" id="cardMode">
            <h5 class="card-title">Pilih Mode &amp; Ruangan</h5>
            <!-- Warning Banner -->
            <div class="alert-warning">
              <svg
                class="alert-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"
                ></path>
                <line x1="12" y1="9" x2="12" y2="13"></line>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
              </svg>
              <p class="alert-text">
                Batas waktu pengajuan adalah <strong
                  >H-1 sebelum kegiatan</strong
                >. Pastikan pengajuan dilakukan tepat waktu.
              </p>
            </div>

            <!-- Activity Type Cards -->
            <div class="type-cards">
              <!-- Full Offline Card -->
              <div class="type-card" id="card-offline" data-mode="offline">
                <div class="type-icon">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                  </svg>
                </div>
                <div class="type-label">Full Offline</div>
                <div class="type-desc">
                  Kegiatan tatap muka di ruang yang dipilih
                </div>
              </div>

              <!-- Hybrid Card -->
              <div class="type-card" id="card-hybrid" data-mode="hybrid">
                <div class="type-icon">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path
                      d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.5a16 16 0 0 0 6 6l.94-.94a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                    ></path>
                  </svg>
                </div>
                <div class="type-label">Hybrid</div>
                <div class="type-desc">
                  Kombinasi tatap muka dan virtual/online
                </div>
              </div>
            </div>
          </div>

          <!-- ============ STEP 2: RUANGAN & JADWAL (muncul setelah mode dipilih) ============ -->
          <div
            class="card jadwal-section"
            id="cardJadwal"
            style="display:none;"
          >
            <h5 class="card-title">
              Pilih Ruangan &amp; Jadwal
              <span class="mode-badge" id="modeBadge"></span>
            </h5>

            <div class="panel-grid">
              <!-- ── LEFT PANEL ── -->
              <div class="panel-left">
                <div class="panel-head">
                  <span>🏢</span>
                  <div>
                    <p class="panel-title">Gedung &amp; Ruangan</p>
                    <p class="panel-sub">Pilih gedung lalu klik ruangan</p>
                  </div>
                </div>

                <!-- Tabs gedung -->
                <div class="gedung-tabs">
                  {
                    ["Gedung 1", "Gedung 2", "Gedung 3", "Outdoor"].map(
                      (g, i) => (
                        <button
                          class={`gtab${i === 0 ? " active" : ""}`}
                          data-gedung={g}
                        >
                          {g}
                        </button>
                      ),
                    )
                  }
                </div>

                <!-- Foto gedung -->
                <div class="gedung-foto">
                  <img
                    class="gedung-foto-image"
                    src="../../../src/assets/gedung1.png"
                    alt="Gedung 1"
                  />
                  <div class="gedung-foto-label">
                    <span>Gedung 1</span>
                    <p>Lantai 1 & 2</p>
                  </div>
                </div>

                <!-- Daftar ruangan -->
                <div class="room-list">
                  {
                    rooms.map((r) => (
                      <button
                        class="room-item"
                        data-id={r.id}
                        data-room={JSON.stringify(r)}
                      >
                        <div class="room-info">
                          <p class="room-name">{r.name}</p>
                          <p class="room-meta">
                            {r.floor}
                            <svg
                              width="11"
                              height="11"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                            >
                              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                              <circle cx="9" cy="7" r="4" />
                              <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                              <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                            </svg>
                            {r.capacity}
                          </p>
                        </div>
                        <span class={`room-dot ${r.status}`} />
                      </button>
                    ))
                  }
                </div>
              </div>

              <!-- ── RIGHT PANEL ── -->
              <div class="panel-right">
                <!-- Empty state -->
                <div class="empty-state" id="emptyState">
                  <div class="empty-icon">
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.2"
                    >
                      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                      ></path>
                      <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                  </div>
                  <h3>Pilih ruangan terlebih dahulu</h3>
                  <p>
                    Klik ruangan di panel kiri untuk melihat foto, kalender
                    ketersediaan, dan pilih jadwal booking.
                  </p>
                </div>

                <!-- Room detail -->
                <div class="room-detail" id="roomDetail">
                  <!-- Foto carousel -->
                  <div class="carousel" id="carousel">
                    <div class="carousel-track" id="carouselTrack">
                      <div class="carousel-slide">
                        <div class="foto-placeholder"></div>
                      </div>
                      <div class="carousel-slide">
                        <div class="foto-placeholder"></div>
                      </div>
                      <div class="carousel-slide">
                        <div class="foto-placeholder"></div>
                      </div>
                    </div>
                    <button class="carousel-btn prev" id="carouselPrev"
                      >‹</button
                    >
                    <button class="carousel-btn next" id="carouselNext"
                      >›</button
                    >
                    <div class="carousel-badge lantai" id="badgeLantai">
                      Lantai 2
                    </div>
                    <div class="carousel-badge kapasitas" id="badgeKapasitas">
                      👥 200 orang
                    </div>
                    <div class="carousel-dots" id="carouselDots"></div>
                  </div>

                  <!-- Info ruangan -->
                  <div class="detail-info">
                    <h2 class="detail-name" id="detailName">—</h2>
                    <p class="detail-loc" id="detailLoc">—</p>
                    <div class="fasilitas-list" id="fasilitasList"></div>
                  </div>

                  <!-- Pilih Tanggal & Slot Jam -->
                  <div class="jadwal-grid">
                    <!-- Kalender -->
                    <div class="jadwal-card jadwal-calendar-card">
                      <div class="calendar-header">
                        <div>
                          <div class="calendar-title">Pilih Tanggal</div>
                          <div class="calendar-subtitle">
                            <span id="selectedCount">5/5 hari</span>
                          </div>
                        </div>
                        <div class="calendar-nav">
                          <button class="cal-arrow" type="button" id="calPrev"
                            >←</button
                          >
                          <span id="calMonthLabel"
                            >{
                              formatMonthLabel(kalenderDates[0].slice(0, 7))
                            }</span
                          >
                          <button class="cal-arrow" type="button" id="calNext"
                            >→</button
                          >
                        </div>
                      </div>
                      <div class="legend legend-inline">
                        <span class="legend-dot available"></span>Tersedia
                        <span class="legend-dot sebagian"></span>Sebagian
                        <span class="legend-dot penuh"></span>Penuh
                      </div>
                      <div class="date-row" id="dateRow">
                        {
                          kalenderDates.map((date) => (
                            <button
                              class={`date-card ${kalenderStatus[date] ?? "available"} ${date >= "2026-04-26" && date <= "2026-04-30" ? "selected" : ""}`}
                              data-date={date}
                              data-status={kalenderStatus[date]}
                              data-month={date.slice(0, 7)}
                              type="button"
                            >
                              <span class="date-day">
                                {formatDayLabel(date)}
                              </span>
                              <span class="date-number">{date.slice(-2)}</span>
                            </button>
                          ))
                        }
                      </div>
                    </div>

                    <!-- Slot jam -->
                    <div class="jadwal-card jadwal-slot-card">
                      <div class="jadwal-card-head">
                        <span>🕐</span>
                        <h4>Pilih Slot Jam</h4>
                      </div>
                      <p class="slot-hint">
                        Per 1 jam, bisa multi-pilih.
                        <span class="legend-dot penuh"></span>=Penuh
                        <span class="legend-dot sebagian"></span>=Sebagian
                      </p>
                      <div class="slot-summary">
                        <div class="summary-card summary-full">
                          Seharian<br /><span>08:00 - 17:00</span>
                        </div>
                        <div class="summary-card summary-morning">
                          Pagi<br /><span>08:00 - 12:00</span>
                        </div>
                        <div class="summary-card summary-afternoon">
                          Siang<br /><span>13:00 - 16:00</span>
                        </div>
                      </div>
                      <div class="slot-grid" id="slotGrid">
                        {
                          jamSlots.map((j, index) => {
                            const endHour =
                              String(Number(j.slice(0, 2)) + 1).padStart(
                                2,
                                "0",
                              ) + ":00";
                            return (
                              <button
                                class={`slot-btn ${jamStatus[j] ?? "available"}`}
                                data-jam={j}
                                type="button"
                              >
                                <span class="slot-time">{j}</span>
                                <span class="slot-range">- {endHour}</span>
                                <span class="slot-action">{jamStatus[j]}</span>
                              </button>
                            );
                          })
                        }
                      </div>
                    </div>
                  </div>
                  <!-- /jadwal-grid -->

                  <!-- Aksi -->
                  <div class="action-row">
                    <button class="btn-back" id="btnGantiMode"
                      >← Ganti Mode</button
                    >
                    <button class="btn-next" id="btnLanjut"
                      >Lanjut ke Konfirmasi →</button
                    >
                  </div>
                </div>
                <!-- /room-detail -->
              </div>
              <!-- /panel-right -->
            </div>
            <!-- /panel-grid -->
          </div>
          <!-- /cardJadwal -->
        </div>
      </main>
    </div>

    <script>
      // ====== STATE ======
      let selectedMode = null;

      const cardMode = document.getElementById("cardMode");
      const cardJadwal = document.getElementById("cardJadwal");
      const modeBadge = document.getElementById("modeBadge");
      const emptyState = document.getElementById("emptyState");
      const roomDetail = document.getElementById("roomDetail");

      const modeLabel = {
        offline: "Full Offline",
        hybrid: "Hybrid",
      };

      // ====== PILIH MODE (Full Offline / Hybrid) ======
      document.querySelectorAll(".type-card").forEach((card) => {
        card.addEventListener("click", () => {
          const mode = card.dataset.mode;
          if (!mode) {
            return;
          }
          selectedMode = mode;

          // Highlight card terpilih
          document
            .querySelectorAll(".type-card")
            .forEach((c) => c.classList.remove("selected"));
          card.classList.add("selected");

          // Tampilkan badge mode di section jadwal
          if (modeBadge) {
            modeBadge.textContent = modeLabel[mode] ?? mode;
          }

          // Tampilkan section ruangan & jadwal di bawah
          if (cardJadwal) {
            cardJadwal.style.display = "block";
            cardJadwal.scrollIntoView({ behavior: "smooth", block: "start" });
          }
        });
      });

      // ====== GANTI MODE (kembali fokus ke pilihan mode) ======
      document.getElementById("btnGantiMode")?.addEventListener("click", () => {
        cardMode?.scrollIntoView({ behavior: "smooth", block: "start" });
      });

      // ====== Carousel ======
      let currentSlide = 0;
      const track = document.getElementById("carouselTrack");
      const dots = document.getElementById("carouselDots");
      const totalSlides = 3;

      function updateCarousel() {
        if (!track || !dots) {
          return;
        }
        track.style.transform = `translateX(-${currentSlide * 100}%)`;
        dots.querySelectorAll(".dot").forEach((d, i) => {
          d.classList.toggle("active", i === currentSlide);
        });
      }

      document.getElementById("carouselPrev")?.addEventListener("click", () => {
        currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
        updateCarousel();
      });
      document.getElementById("carouselNext")?.addEventListener("click", () => {
        currentSlide = (currentSlide + 1) % totalSlides;
        updateCarousel();
      });

      if (dots) {
        for (let i = 0; i < totalSlides; i++) {
          const d = document.createElement("span");
          d.className = "dot" + (i === 0 ? " active" : "");
          dots.appendChild(d);
        }
      }

      // ====== Room select ======
      const roomButtons = document.querySelectorAll(".room-item");

      roomButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          roomButtons.forEach((b) => b.classList.remove("selected"));
          btn.classList.add("selected");

          const roomData = btn.dataset.room;
          const r = roomData ? JSON.parse(roomData) : null;
          if (!r) {
            return;
          }

          const detailName = document.getElementById("detailName");
          const detailLoc = document.getElementById("detailLoc");
          const badgeLantai = document.getElementById("badgeLantai");
          const badgeKapasitas = document.getElementById("badgeKapasitas");

          if (detailName) {
            detailName.textContent = r.name;
          }
          if (detailLoc) {
            detailLoc.textContent = `${r.floor} — ${r.gedung}`;
          }
          if (badgeLantai) {
            badgeLantai.textContent = r.floor;
          }
          if (badgeKapasitas) {
            badgeKapasitas.textContent = `👥 ${r.capacity} orang`;
          }

          const fl = document.getElementById("fasilitasList");
          if (fl) {
            fl.innerHTML = r.fasilitas
              .map((f) => `<span class="fas-tag">${f}</span>`)
              .join("");
          }

          currentSlide = 0;
          updateCarousel();

          if (emptyState) {
            emptyState.style.display = "none";
          }
          if (roomDetail) {
            roomDetail.style.display = "flex";
          }
        });
      });

      // ====== Slot jam toggle ======
      document.querySelectorAll(".slot-btn:not([disabled])").forEach((btn) => {
        btn.addEventListener("click", () => {
          btn.classList.toggle("selected");
          const action = btn.querySelector(".slot-action");
          if (action) {
            action.textContent = btn.classList.contains("selected")
              ? "✓ Dipilih"
              : "Pilih";
          }
        });
      });

      // Kalender: custom tanggal kustom dengan status warna
      const dateCards = document.querySelectorAll(".date-card");
      const selectedCount = document.getElementById("selectedCount");
      const monthLabel = document.getElementById("calMonthLabel");
      const prevMonthBtn = document.getElementById("calPrev");
      const nextMonthBtn = document.getElementById("calNext");
      const monthOptions = Array.from(
        new Set(
          Array.from(dateCards)
            .map((btn) => btn.dataset.month)
            .filter((month) => !!month),
        ),
      ).sort();
      let currentMonthIndex = 0;
      let selectedStart = "2026-04-26";
      let selectedEnd = "2026-04-30";

      function getDayDiff(start, end) {
        const d1 = new Date(start);
        const d2 = new Date(end);
        return Math.round(
          (d2.getTime() - d1.getTime()) / (1000 * 60 * 60 * 24),
        );
      }

      function formatMonthLabel(monthKey) {
        const [year, month] = monthKey.split("-");
        const date = new Date(`${year}-${month}-01`);
        return date.toLocaleString("id-ID", { month: "long", year: "numeric" });
      }

      function updateMonthView() {
        if (
          !monthLabel ||
          !prevMonthBtn ||
          !nextMonthBtn ||
          monthOptions.length === 0
        ) {
          return;
        }

        const currentMonth = monthOptions[currentMonthIndex];
        monthLabel.textContent = formatMonthLabel(currentMonth);
        dateCards.forEach((btn) => {
          btn.classList.toggle(
            "hidden-month",
            btn.dataset.month !== currentMonth,
          );
        });
        prevMonthBtn.disabled = currentMonthIndex === 0;
        nextMonthBtn.disabled = currentMonthIndex === monthOptions.length - 1;
      }

      function updateSelectedDates() {
        dateCards.forEach((btn) => {
          const date = btn.dataset.date;
          if (!date) {
            return;
          }

          const inRange =
            selectedStart && selectedEnd
              ? date >= selectedStart && date <= selectedEnd
              : date === selectedStart;
          btn.classList.toggle("selected", inRange);
        });

        const count = selectedEnd
          ? getDayDiff(selectedStart, selectedEnd) + 1
          : 1;
        if (selectedCount) {
          selectedCount.textContent = `${count}/5 hari`;
        }
      }

      dateCards.forEach((btn) => {
        if (btn.dataset.status === "penuh") {
          btn.classList.add("disabled");
        }

        btn.addEventListener("click", () => {
          if (btn.dataset.status === "penuh") {
            return;
          }

          const date = btn.dataset.date;
          if (!date) {
            return;
          }

          if (!selectedStart || (selectedStart && selectedEnd)) {
            selectedStart = date;
            selectedEnd = "";
          } else {
            selectedEnd = date;
            if (selectedEnd < selectedStart) {
              [selectedStart, selectedEnd] = [selectedEnd, selectedStart];
            }
          }
          updateSelectedDates();
        });
      });

      prevMonthBtn?.addEventListener("click", () => {
        if (currentMonthIndex > 0) {
          currentMonthIndex -= 1;
          updateMonthView();
        }
      });

      nextMonthBtn?.addEventListener("click", () => {
        if (currentMonthIndex < monthOptions.length - 1) {
          currentMonthIndex += 1;
          updateMonthView();
        }
      });

      updateMonthView();
      updateSelectedDates();

      // ====== Lanjut ke Konfirmasi ======
      document.getElementById("btnLanjut")?.addEventListener("click", () => {
        const params = new URLSearchParams(window.location.search);
        const role = params.get("role") ?? "";
        const slots = [...document.querySelectorAll(".slot-btn.selected")]
          .map((b) => b.dataset.jam)
          .join(",");
        const room =
          document.querySelector(".room-item.selected")?.dataset.id ?? "";

        if (!selectedMode) {
          alert(
            "Harap pilih mode kegiatan (Full Offline / Hybrid) terlebih dahulu.",
          );
          return;
        }
        if (!room || !selectedStart || !slots) {
          alert("Harap pilih ruangan, tanggal, dan minimal 1 slot jam.");
          return;
        }

        const tglISO = selectedStart;

        window.location.href = `./ajukan/konfirmasi?role=${encodeURIComponent(role)}&mode=${selectedMode}&room=${room}&tgl=${tglISO}&jam=${slots}`;
      });
