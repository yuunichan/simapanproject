---
// SI MAPAN - Ajukan Penggunaan Ruangan
// Astro component matching the provided design

import Sidebar from '../../components/sidebar_admin.astro';
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SI MAPAN - Ajukan Penggunaan Ruangan</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../../src/styles/admin.css" />
</head>
<body>

<div class="layout">
  <!-- Sidebar -->
    <Sidebar activePage="ajukan" />


  <!-- Main Content -->
  <main class="main">
    <!-- Top Header -->
    <header class="topbar">
      <div class="topbar-title">
        <h1 class="page-title">Ajukan Penggunaan Ruangan</h1>
        <p class="page-subtitle">Ikuti langkah berikut</p>
      </div>
      <div class="header-actions">
        <button class="notif-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
          </svg>
          <span class="notif-dot"></span>
        </button>
      </div>
    </header>

    <!-- Content Area -->
    <div class="content">
      <div class="card">
        <h2 class="card-title">Pilih Tipe Kegiatan</h2>

        <!-- Warning Banner -->
        <div class="alert-warning">
          <svg class="alert-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
          <p class="alert-text">
            Batas waktu pengajuan adalah <strong>H-1 sebelum kegiatan</strong>. Pastikan pengajuan dilakukan tepat waktu.
          </p>
        </div>

        <!-- Activity Type Cards -->
        <div class="type-cards">
          <!-- Full Offline Card (selected) -->
          <div class="type-card selected" id="card-offline" onclick="selectCard('offline')">
            <div class="type-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <div class="type-label">Full Offline</div>
            <div class="type-desc">Kegiatan tatap muka di ruang yang dipilih</div>
          </div>

          <!-- Hybrid Card -->
          <div class="type-card" id="card-hybrid" onclick="selectCard('hybrid')">
            <div class="type-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.5a16 16 0 0 0 6 6l.94-.94a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div class="type-label">Hybrid</div>
            <div class="type-desc">Kombinasi tatap muka dan virtual/online</div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
  // Highlight card saat diklik
  function selectCard(type: string) {
    document.querySelectorAll('.type-card').forEach(c => c.classList.remove('selected'));
    document.getElementById('card-' + type)?.classList.add('selected');
  }
 
  // Klik Full Offline → langsung ke step 2
  document.getElementById('card-offline')?.addEventListener('click', () => {
    const params = new URLSearchParams(window.location.search);
    const role = params.get('role') ?? '';
    window.location.href = `./ajukan/ruangan-jadwal?mode=offline&role=${encodeURIComponent(role)}`;
  });
 
  // Klik Hybrid → ke step 2 dengan mode hybrid
  document.getElementById('card-hybrid')?.addEventListener('click', () => {
    const params = new URLSearchParams(window.location.search);
    const role = params.get('role') ?? '';
    window.location.href = `./ajukan/ruangan-jadwal?mode=hybrid&role=${encodeURIComponent(role)}`;
  });
</script>
 

</body>
</html>