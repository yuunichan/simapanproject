---
// Admin Login Page - SI MAPAN

import '../../styles/global.css';
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login - SI MAPAN</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="card">
      <div class="logo-area">
        <div class="logo-badge">
          <div class="logo-text">
            <span class="si">SI</span>
            <span class="mapan">MAPAN</span>
          </div>
        </div>
        <p class="logo-tagline">
          Sistem ruMAh tangga dan kearsiPAN <br />
          <strong>ADMINISTRATOR</strong>
        </p>
      </div>

      <div class="step-dots">
        <div class="dot"></div>
        <div class="dot active"></div>
      </div>

      <form id="adminLoginForm">
        <div class="form-group">
          <label class="form-label" for="username">Username</label>
          <input 
            type="text" 
            id="username" 
            class="form-input" 
            placeholder="Masukkan username admin" 
            required 
          />
        </div>

        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <input 
            type="password" 
            id="password" 
            class="form-input" 
            placeholder="••••••••" 
            required 
          />
        </div>

        <button type="submit" class="btn-primary" id="loginBtn">
          <span class="spinner"></span>
          <span class="btn-label">MASUK KE DASHBOARD</span>
        </button>
      </form>

      <div class="divider">atau</div>

      <a href="/" class="back-link">
        <span class="back-arrow">←</span> Kembali pilih role
      </a>
    </div>

        <script>
        const loginForm = document.getElementById('adminLoginForm');
        const loginBtn = document.getElementById('loginBtn');

        loginForm?.addEventListener('submit', (e) => {
            e.preventDefault();
            
            // Aktifkan loading animation
            if (loginBtn) {
            loginBtn.classList.add('loading');
            loginBtn.setAttribute('disabled', 'true');
            }

            // Simulasi Validasi / API Call
            setTimeout(() => {
            // PERBAIKAN 1: Panggil ID input yang benar sesuai HTML ('username' & 'password')
            const usernameInput = document.getElementById('username') as HTMLInputElement;
            const passwordInput = document.getElementById('password') as HTMLInputElement;

            const username = usernameInput?.value;
            const password = passwordInput?.value;

            // PERBAIKAN 2: Di sini tempat kamu mengecek teks isinya
            if (username === 'admin' && password === 'admin123') {
                // PERBAIKAN 3: Arahkan ke rute folder admin/dashboard yang benar
                window.location.href = '/admin/dashboard?role=admin';
            } else {
                alert('Username atau Password Admin salah!');
                
                // Matikan loading jika gagal agar user bisa coba lagi
                if (loginBtn) {
                loginBtn.classList.remove('loading');
                loginBtn.removeAttribute('disabled');
                }
            }
            }, 1500);
        });
        </script>    
  </body>
</html>