---
// SI MAPAN - Dashboard Beranda
// Penggunaan Ruangan — User View
import Sidebar from '../../components/sidebar_admin.astro';
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SI MAPAN — Beranda</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Serif+Display&display=swap" rel="stylesheet" />  
    <link rel="stylesheet" href="../../../src/styles/admin.css" />
  </head>

  <body>
    <div class="layout">

      <!-- Sidebar -->
    <Sidebar activePage="beranda" />
      <!-- ── Main ── -->
      <div class="main">

        <!-- Topbar -->
        <header class="topbar">
          <div class="topbar-title">
            <h1>Beranda</h1>
            <p>Selamat datang di SI MAPAN</p>
          </div>
          <div class="topbar-actions">
            <button class="notif-btn" title="Notifikasi">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zm0 16a2 2 0 01-2-2h4a2 2 0 01-2 2z"/>
              </svg>
              <span class="notif-dot"></span>
            </button>
          </div>
        </header>

        <!-- Page content -->
        <main class="content">

          <!-- Hero -->
          <div class="hero">
            <div class="hero-text">
              <p class="hero-greeting">Selamat datang,</p>
              <h2 class="hero-name">Andi Prasetyo</h2>
              <p class="hero-division">Divisi Teknologi Informasi</p>
            </div>
            <button class="btn-ajukan" id="ajukanBtn">+ Ajukan Ruangan</button>
          </div>

          <!-- Stats -->
          <div class="stats-row">
            <div class="stat-card green">
              <p class="stat-label">Disetujui</p>
              <p class="stat-value">1</p>
              <p class="stat-sub">75% approval rate</p>
            </div>
            <div class="stat-card green2">
              <p class="stat-label">Disetujui</p>
              <p class="stat-value">1</p>
              <p class="stat-sub">75% approval rate</p>
            </div>
            <div class="stat-card yellow">
              <p class="stat-label">Menunggu</p>
              <p class="stat-value">1</p>
              <p class="stat-sub">Perlu tindakan</p>
            </div>
          </div>

          <!-- Recent submissions table -->
          <div class="table-card">
            <div class="table-header">
              <span class="table-title">Pengajuan Terbaru</span>
              <a href="#" class="lihat-semua">Lihat Semua →</a>
            </div>
            <table>
              <thead>
                <tr>
                  <th>No. Tiket</th>
                  <th>Ruangan</th>
                  <th>Tanggal</th>
                  <th>Status</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><a href="#" class="ticket-link">R/012/03/2026</a></td>
                  <td>Ruang Mawar — Gedung 1</td>
                  <td class="td-date">15 Mar 2026</td>
                  <td><span class="badge badge-menunggu">Menunggu</span></td>
                  <td><button class="btn-action">Tiket</button></td>
                </tr>
                <tr>
                  <td><a href="#" class="ticket-link">R/011/03/2026</a></td>
                  <td>Ruang CAT 1 — Gedung 2</td>
                  <td class="td-date">10 Mar 2026</td>
                  <td><span class="badge badge-disetujui">Disetujui</span></td>
                  <td><button class="btn-action">Tiket</button></td>
                </tr>
                <tr>
                  <td><a href="#" class="ticket-link">R/010/02/2026</a></td>
                  <td>Aula — Gedung 1</td>
                  <td class="td-date">28 Feb 2026</td>
                  <td><span class="badge badge-ditolak">Ditolak</span></td>
                  <td><button class="btn-action">Detail</button></td>
                </tr>
              </tbody>
            </table>
          </div>

        </main>
      </div>
    </div>

    <script>
      // Active nav highlight
      document.querySelectorAll('.nav-item').forEach(item => {
        item.addEventListener('click', (e) => {
          e.preventDefault();
          document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
          (item as HTMLElement).classList.add('active');
        });
      });



      // Action buttons
      document.querySelectorAll('.btn-action').forEach(btn => {
        btn.addEventListener('click', () => {
          const row = (btn as HTMLElement).closest('tr');
          const ticket = row?.querySelector('.ticket-link')?.textContent;
          const action = (btn as HTMLElement).textContent?.trim();
          console.log(`${action} for ticket: ${ticket}`);
          // TODO: handle tiket/detail actions
        });
      });
    </script>
  </body>
</html>