---
import Layout from "../../layouts/Layout.astro";
import SidebarAdmin from "../../components/sidebaradmin.astro";

const pengajuanTerbaru = [
    {
        noTiket: "R/013/03/2026",
        pemohon: "Siti Rahayu",
        ruangan: "Ruang Mawar",
        tanggal: "16 Mar 2026",
        status: "menunggu",
    },
    {
        noTiket: "R/012/03/2026",
        pemohon: "Andi Prasetyo",
        ruangan: "Ruang Mawar",
        tanggal: "15 Mar 2026",
        status: "menunggu",
    },
    {
        noTiket: "R/011/03/2026",
        pemohon: "Andi Prasetyo",
        ruangan: "Ruang CAT 1",
        tanggal: "10 Mar 2026",
        status: "disetujui",
    },
];

const statusLabel = {
    menunggu: "Menunggu",
    disetujui: "Disetujui",
    ditolak: "Ditolak",
};

---
<html>
<Layout title="Dashboard Admin — SI MAPAN">
    <div class="layout">
        <SidebarAdmin activePage="dashboard" />

        <div class="main">
            <header class="topbar">
                <div class="topbar-title">
                    <h1>Dashboard Admin</h1>
                    <p>Rekap pengajuan sistem</p>
                </div>
                <div class="topbar-actions">
                    <button class="notif-btn" title="Notifikasi">
                        <svg viewBox="0 0 20 20" fill="currentColor">
                            <path
                                d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM8.5 16a1.5 1.5 0 003 0h-3z"
                            ></path>
                        </svg>
                        <span class="notif-dot"></span>
                    </button>
                </div>
            </header>

            <main class="content">
                <section class="stats-row">
                    <div class="stat-card blue">
                        <p class="stat-label">Total Pengajuan</p>
                        <p class="stat-value">3</p>
                        <p class="stat-sub">Bulan Maret 2026</p>
                    </div>
                    <div class="stat-card yellow">
                        <p class="stat-label">Menunggu</p>
                        <p class="stat-value">2</p>
                        <p class="stat-sub">Perlu tindakan</p>
                    </div>
                    <div class="stat-card green">
                        <p class="stat-label">Disetujui</p>
                        <p class="stat-value">1</p>
                        <p class="stat-sub">74.5% approval</p>
                    </div>
                    <div class="stat-card red">
                        <p class="stat-label">Ditolak</p>
                        <p class="stat-value">0</p>
                        <p class="stat-sub">Bulan ini</p>
                    </div>
                </section>

                <section class="table-card">
                    <div class="table-header">
                        <div class="table-title">
                            <span class="table-title-bar"></span>
                            Pengajuan Terbaru
                        </div>
                        <a href="/superadmin/persetujuan" class="lihat-semua"
                            >Lihat Semua →</a
                        >
                    </div>

                    <table>
                        <thead>
                            <tr>
                                <th>No. Tiket</th>
                                <th>Pemohon</th>
                                <th>Ruangan</th>
                                <th>Tanggal</th>
                                <th>Status</th>
                                <th>Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            {
                                pengajuanTerbaru.map((item) => (
                                    <tr>
                                        <td>
                                            <a
                                                href={`/superadmin/persetujuan/${item.noTiket}`}
                                                class="ticket-link"
                                            >
                                                {item.noTiket}
                                            </a>
                                        </td>
                                        <td>{item.pemohon}</td>
                                        <td>{item.ruangan}</td>
                                        <td class="td-date">{item.tanggal}</td>
                                        <td>
                                            <span class={`badge badge-${item.status}`}>
                                                {statusLabel[item.status]}
                                            </span>
                                        </td>
                                        <td>
                                            {item.status === "menunggu" ? (
                                                <div class="aksi-group">
                                                    <button class="btn-setuju">Setuju</button>
                                                    <button class="btn-tolak">Tolak</button>
                                                </div>
                                            ) : (
                                                <button class="btn-action">Lihat</button>
                                            )}
                                        </td>
                                    </tr>
                                ))
                            }
                        </tbody>
                    </table>
                </section>
            </main>
        </div>
    </div>
</Layout>

<style>
    /*
      Tambahan style baru (tidak mengubah rule yang sudah ada di CSS global):
      - varian merah untuk stat-card "Ditolak" (sebelumnya hanya blue/green/yellow)
      - tombol Setuju (hijau) & Tolak (merah) untuk baris status "menunggu"
    */
    .stat-card.red {
        border-left-color: #dc2626;
    }
    .stat-card.red::after {
        background: #dc2626;
    }
    .stat-card.red .stat-label {
        color: #dc2626;
    }

    .aksi-group {
        display: flex;
        gap: 8px;
    }

    .btn-setuju {
        font-size: 12px;
        padding: 5px 14px;
        border-radius: 6px;
        border: 2px solid #16a34a;
        background: transparent;
        color: #16a34a;
        cursor: pointer;
        font-weight: bold;
    }
    .btn-setuju:hover {
        background: #f0fdf4;
    }

    .btn-tolak {
        font-size: 12px;
        padding: 5px 14px;
        border-radius: 6px;
        border: 2px solid #dc2626;
        background: transparent;
        color: #dc2626;
        cursor: pointer;
        font-weight: bold;
    }
    .btn-tolak:hover {
        background: #fef2f2;
    }
</style>