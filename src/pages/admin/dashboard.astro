---
// SI MAPAN - Dashboard Beranda
// Penggunaan Ruangan — User View
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SI MAPAN — Beranda</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Serif+Display&display=swap" rel="stylesheet" />

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        /* sidebar */
        --sidebar-bg: #1e2433;
        --sidebar-w: 200px;
        --sidebar-text: #a8b3c8;
        --sidebar-active-bg: #2d3650;
        --sidebar-active-text: #ffffff;
        --sidebar-label: #5a6680;
        --sidebar-accent: #c0392b;

        /* main */
        --page-bg: #f4f6f9;
        --topbar-bg: #ffffff;
        --topbar-border: #e8eaf0;

        /* cards */
        --card-bg: #ffffff;
        --card-shadow: 0 1px 4px rgba(0,0,0,0.08);
        --card-radius: 12px;

        /* hero */
        --hero-bg-start: #4da8d4;
        --hero-bg-end:   #3b8cb8;

        /* stat borders */
        --stat-green:  #22c55e;
        --stat-yellow: #f59e0b;

        /* text */
        --text-1: #111827;
        --text-2: #4b5563;
        --text-3: #9ca3af;

        /* status badges */
        --badge-menunggu-bg: #fef3c7;
        --badge-menunggu-text: #92400e;
        --badge-disetujui-bg: #d1fae5;
        --badge-disetujui-text: #065f46;
        --badge-ditolak-bg: #fee2e2;
        --badge-ditolak-text: #991b1b;

        /* link */
        --link: #3b82f6;

        /* btn */
        --btn-primary: #ffffff;
        --btn-primary-text: #1a5f8a;
        --btn-outline-border: #d1d5db;
      }

      html, body { height: 100%; font-family: 'DM Sans', sans-serif; background: var(--page-bg); }

      /* ────────────────────────────────────────
         LAYOUT
      ──────────────────────────────────────── */
      .layout {
        display: flex;
        min-height: 100vh;
      }

      /* ── Sidebar ── */
      .sidebar {
        width: var(--sidebar-w);
        min-height: 100vh;
        background: var(--sidebar-bg);
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        position: fixed;
        top: 0; left: 0; bottom: 0;
        z-index: 100;
      }

      .sidebar-logo {
        padding: 20px 18px 18px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 2px;
      }

      .logo-badge {
        display: inline-flex;
        align-items: center;
        border: 2px solid #c0392b;
        border-radius: 40px;
        padding: 3px 12px;
        margin-bottom: 3px;
      }

      .logo-badge span {
        font-size: 15px;
        font-weight: 700;
        letter-spacing: 0.05em;
        color: #c0392b;
      }

      .logo-tagline {
        font-size: 9.5px;
        color: #7a8599;
        letter-spacing: 0.02em;
        line-height: 1.4;
      }

      .logo-tagline strong { color: #c0392b; font-weight: 600; }

      /* Nav sections */
      .nav-section {
        padding: 20px 0 8px;
      }

      .nav-section-label {
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--sidebar-label);
        padding: 0 18px 8px;
      }

      .nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 18px;
        color: var(--sidebar-text);
        font-size: 13px;
        font-weight: 400;
        cursor: pointer;
        text-decoration: none;
        border-radius: 0;
        transition: background 0.15s, color 0.15s;
        border-left: 3px solid transparent;
        margin: 1px 0;
      }

      .nav-item:hover {
        background: rgba(255,255,255,0.05);
        color: #fff;
      }

      .nav-item.active {
        background: var(--sidebar-active-bg);
        color: var(--sidebar-active-text);
        border-left-color: #3b82f6;
        font-weight: 500;
      }

      .nav-item svg { flex-shrink: 0; opacity: 0.7; }
      .nav-item.active svg { opacity: 1; }

      /* User footer */
      .sidebar-footer {
        margin-top: auto;
        padding: 14px 16px;
        border-top: 1px solid rgba(255,255,255,0.06);
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .avatar {
        width: 32px; height: 32px;
        border-radius: 50%;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0;
      }

      .user-info { flex: 1; min-width: 0; }

      .user-name {
        font-size: 12.5px;
        font-weight: 600;
        color: #e2e8f0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .user-role {
        font-size: 10.5px;
        color: var(--sidebar-label);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .logout-btn {
        background: none;
        border: none;
        cursor: pointer;
        color: var(--sidebar-label);
        padding: 4px;
        border-radius: 4px;
        transition: color 0.15s;
        display: flex;
        align-items: center;
      }

      .logout-btn:hover { color: #ef4444; }

      /* ── Main area ── */
      .main {
        margin-left: var(--sidebar-w);
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      /* Topbar */
      .topbar {
        background: var(--topbar-bg);
        border-bottom: 1px solid var(--topbar-border);
        padding: 0 28px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 50;
      }

      .topbar-title h1 {
        font-size: 15px;
        font-weight: 600;
        color: var(--text-1);
      }

      .topbar-title p {
        font-size: 11.5px;
        color: var(--text-3);
        margin-top: 1px;
      }

      .topbar-actions { display: flex; align-items: center; gap: 12px; }

      .notif-btn {
        position: relative;
        background: none;
        border: none;
        cursor: pointer;
        padding: 6px;
        color: var(--text-2);
        border-radius: 8px;
        transition: background 0.15s;
        display: flex;
        align-items: center;
      }

      .notif-btn:hover { background: #f3f4f6; }

      .notif-dot {
        position: absolute;
        top: 5px; right: 5px;
        width: 8px; height: 8px;
        border-radius: 50%;
        background: #ef4444;
        border: 2px solid #fff;
      }

      /* ── Page content ── */
      .content {
        padding: 24px 28px;
        flex: 1;
        animation: pageIn 0.5s cubic-bezier(0.22,1,0.36,1) both;
      }

      @keyframes pageIn {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      /* ── Hero banner ── */
      .hero {
        background: linear-gradient(120deg, var(--hero-bg-start), var(--hero-bg-end));
        border-radius: var(--card-radius);
        padding: 24px 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
        position: relative;
        overflow: hidden;
      }

      .hero::before {
        content: '';
        position: absolute;
        right: -40px; top: -40px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,0.07);
        pointer-events: none;
      }

      .hero::after {
        content: '';
        position: absolute;
        right: 60px; bottom: -60px;
        width: 160px; height: 160px;
        border-radius: 50%;
        background: rgba(255,255,255,0.05);
        pointer-events: none;
      }

      .hero-text { z-index: 1; }

      .hero-greeting {
        font-size: 12px;
        color: rgba(255,255,255,0.75);
        margin-bottom: 3px;
      }

      .hero-name {
        font-family: 'DM Serif Display', serif;
        font-size: 26px;
        color: #ffffff;
        line-height: 1.1;
        margin-bottom: 4px;
      }

      .hero-division {
        font-size: 12.5px;
        color: rgba(255,255,255,0.7);
      }

      .btn-ajukan {
        background: rgba(255,255,255,0.95);
        color: var(--btn-primary-text);
        border: none;
        border-radius: 8px;
        padding: 10px 18px;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        z-index: 1;
        transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
        box-shadow: 0 2px 8px rgba(0,0,0,0.12);
      }

      .btn-ajukan:hover {
        background: #ffffff;
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(0,0,0,0.18);
      }

      /* ── Stat cards ── */
      .stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-bottom: 20px;
      }

      .stat-card {
        background: var(--card-bg);
        border-radius: var(--card-radius);
        box-shadow: var(--card-shadow);
        padding: 18px 20px;
        border-top: 3px solid transparent;
        transition: transform 0.2s, box-shadow 0.2s;
      }

      .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(0,0,0,0.1);
      }

      .stat-card.green  { border-top-color: var(--stat-green); }
      .stat-card.green2 { border-top-color: var(--stat-green); }
      .stat-card.yellow { border-top-color: var(--stat-yellow); }

      .stat-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-3);
        margin-bottom: 6px;
      }

      .stat-value {
        font-size: 36px;
        font-weight: 700;
        color: var(--text-1);
        line-height: 1;
        margin-bottom: 6px;
      }

      .stat-sub {
        font-size: 11.5px;
        color: var(--text-3);
      }

      /* ── Table card ── */
      .table-card {
        background: var(--card-bg);
        border-radius: var(--card-radius);
        box-shadow: var(--card-shadow);
        overflow: hidden;
      }

      .table-header {
        padding: 16px 20px 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid #f3f4f6;
      }

      .table-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-1);
      }

      .lihat-semua {
        font-size: 12.5px;
        color: var(--link);
        text-decoration: none;
        font-weight: 500;
        transition: opacity 0.15s;
      }

      .lihat-semua:hover { opacity: 0.7; text-decoration: underline; }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      thead th {
        padding: 10px 20px;
        text-align: left;
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-3);
        background: #fafafa;
        border-bottom: 1px solid #f0f1f3;
      }

      tbody tr {
        border-bottom: 1px solid #f3f4f6;
        transition: background 0.15s;
      }

      tbody tr:last-child { border-bottom: none; }
      tbody tr:hover { background: #fafbff; }

      tbody td {
        padding: 13px 20px;
        font-size: 13px;
        color: var(--text-1);
        vertical-align: middle;
      }

      .ticket-link {
        color: var(--link);
        font-weight: 500;
        text-decoration: none;
        font-size: 12.5px;
        transition: opacity 0.15s;
      }

      .ticket-link:hover { opacity: 0.7; text-decoration: underline; }

      /* Badges */
      .badge {
        display: inline-flex;
        align-items: center;
        padding: 3px 10px;
        border-radius: 99px;
        font-size: 11.5px;
        font-weight: 600;
        white-space: nowrap;
      }

      .badge-menunggu {
        background: var(--badge-menunggu-bg);
        color: var(--badge-menunggu-text);
      }

      .badge-disetujui {
        background: var(--badge-disetujui-bg);
        color: var(--badge-disetujui-text);
      }

      .badge-ditolak {
        background: var(--badge-ditolak-bg);
        color: var(--badge-ditolak-text);
      }

      /* Action buttons */
      .btn-action {
        background: #fff;
        border: 1.5px solid var(--btn-outline-border);
        border-radius: 6px;
        padding: 5px 14px;
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        font-weight: 500;
        color: var(--text-1);
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
        white-space: nowrap;
      }

      .btn-action:hover {
        background: #f9fafb;
        border-color: #9ca3af;
      }

      /* date column */
      .td-date { color: var(--text-2); font-size: 12.5px; }

      /* ── Responsive (basic) ── */
      @media (max-width: 720px) {
        :root { --sidebar-w: 0px; }
        .sidebar { display: none; }
        .content { padding: 16px; }
        .stats-row { grid-template-columns: 1fr 1fr; }
        .hero { flex-direction: column; gap: 16px; align-items: flex-start; }
      }
    </style>
  </head>

  <body>
    <div class="layout">

      <!-- ── Sidebar ── -->
      <aside class="sidebar">
        <div class="sidebar-logo">  
          <div class="logo-badge"><span>SI MAPAN</span></div>
          <p class="logo-tagline">Sistem ru<strong>MAh</strong> tangga<br>dan kearsi<strong>PAN</strong></p>
        </div>

        <nav class="nav-section">
          <p class="nav-section-label">Penggunaan Ruangan</p>

          <a href="#" class="nav-item active">
            <!-- home icon -->
            <svg width="15" height="15" viewBox="0 0 20 20" fill="currentColor"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h4a1 1 0 001-1v-3h2v3a1 1 0 001 1h4a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/></svg>
            Beranda
          </a>

          <a href="#" class="nav-item">
            <!-- calendar icon -->
            <svg width="15" height="15" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>
            Ajukan Penggunaan
          </a>

          <a href="#" class="nav-item">
            <!-- document icon -->
            <svg width="15" height="15" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg>
            Riwayat Pengajuan
          </a>
        </nav>

        <div class="sidebar-footer">
          <div class="avatar">AP</div>
          <div class="user-info">
            <p class="user-name">Andi Prasetyo</p>
            <p class="user-role">Karyawan</p>
          </div>
          <button class="logout-btn" title="Keluar">
            <svg width="15" height="15" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z" clip-rule="evenodd"/>
            </svg>
          </button>
        </div>
      </aside>

      <!-- ── Main ── -->
      <div class="main">

        <!-- Topbar -->
        <header class="topbar">
          <div class="topbar-title">
            <h1>Beranda</h1>
            <p>Selamat datang di SI MAPAN</p>
          </div>
          <div class="topbar-actions">
            <button class="notif-btn" title="Notifikasi">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zm0 16a2 2 0 01-2-2h4a2 2 0 01-2 2z"/>
              </svg>
              <span class="notif-dot"></span>
            </button>
          </div>
        </header>

        <!-- Page content -->
        <main class="content">

          <!-- Hero -->
          <div class="hero">
            <div class="hero-text">
              <p class="hero-greeting">Selamat datang,</p>
              <h2 class="hero-name">Andi Prasetyo</h2>
              <p class="hero-division">Divisi Teknologi Informasi</p>
            </div>
            <button class="btn-ajukan" id="ajukanBtn">+ Ajukan Ruangan</button>
          </div>

          <!-- Stats -->
          <div class="stats-row">
            <div class="stat-card green">
              <p class="stat-label">Disetujui</p>
              <p class="stat-value">1</p>
              <p class="stat-sub">75% approval rate</p>
            </div>
            <div class="stat-card green2">
              <p class="stat-label">Disetujui</p>
              <p class="stat-value">1</p>
              <p class="stat-sub">75% approval rate</p>
            </div>
            <div class="stat-card yellow">
              <p class="stat-label">Menunggu</p>
              <p class="stat-value">1</p>
              <p class="stat-sub">Perlu tindakan</p>
            </div>
          </div>

          <!-- Recent submissions table -->
          <div class="table-card">
            <div class="table-header">
              <span class="table-title">Pengajuan Terbaru</span>
              <a href="#" class="lihat-semua">Lihat Semua →</a>
            </div>
            <table>
              <thead>
                <tr>
                  <th>No. Tiket</th>
                  <th>Ruangan</th>
                  <th>Tanggal</th>
                  <th>Status</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><a href="#" class="ticket-link">R/012/03/2026</a></td>
                  <td>Ruang Mawar — Gedung 1</td>
                  <td class="td-date">15 Mar 2026</td>
                  <td><span class="badge badge-menunggu">Menunggu</span></td>
                  <td><button class="btn-action">Tiket</button></td>
                </tr>
                <tr>
                  <td><a href="#" class="ticket-link">R/011/03/2026</a></td>
                  <td>Ruang CAT 1 — Gedung 2</td>
                  <td class="td-date">10 Mar 2026</td>
                  <td><span class="badge badge-disetujui">Disetujui</span></td>
                  <td><button class="btn-action">Tiket</button></td>
                </tr>
                <tr>
                  <td><a href="#" class="ticket-link">R/010/02/2026</a></td>
                  <td>Aula — Gedung 1</td>
                  <td class="td-date">28 Feb 2026</td>
                  <td><span class="badge badge-ditolak">Ditolak</span></td>
                  <td><button class="btn-action">Detail</button></td>
                </tr>
              </tbody>
            </table>
          </div>

        </main>
      </div>
    </div>

    <script>
      // Active nav highlight
      document.querySelectorAll('.nav-item').forEach(item => {
        item.addEventListener('click', (e) => {
          e.preventDefault();
          document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
          (item as HTMLElement).classList.add('active');
        });
      });

      // Ajukan button
      document.getElementById('ajukanBtn')?.addEventListener('click', () => {
        // TODO: navigate to submission form
        // window.location.href = '/ajukan-ruangan';
        console.log('Navigate to: ajukan ruangan');
      });

      // Action buttons
      document.querySelectorAll('.btn-action').forEach(btn => {
        btn.addEventListener('click', () => {
          const row = (btn as HTMLElement).closest('tr');
          const ticket = row?.querySelector('.ticket-link')?.textContent;
          const action = (btn as HTMLElement).textContent?.trim();
          console.log(`${action} for ticket: ${ticket}`);
          // TODO: handle tiket/detail actions
        });
      });
    </script>
  </body>
</html>