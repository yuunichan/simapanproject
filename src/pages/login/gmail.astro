---
// SI MAPAN - Sistem ruMAh tangga dan kearsiPAN
// Step 2: Input Email Gmail & Kirim Kode OTP

import '../../styles/global.css';
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SI MAPAN - Verifikasi Email</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <div class="card">
      <!-- Logo -->
      <div class="logo-area">
        <div class="logo-badge">
          <span class="logo-text">SI MAPAN</span>
        </div>
        <p class="logo-tagline">
          Sistem ru<strong>MAh</strong> tangga dan kearsi<strong>PAN</strong>
        </p>
      </div>

      <!-- Step Dots: step 2 active -->
      <div class="step-dots">
        <div class="dot"></div>
        <div class="dot active"></div>
        <div class="dot"></div>
      </div>

      <!-- Email Input -->
      <div class="form-group" id="emailGroup">
        <label class="form-label" for="emailInput">Email Gmail BKN</label>
        <input
          type="email"
          id="emailInput"
          name="email"
          class="form-input"
          placeholder="andi.prasetyo@bkn.go.id"
          autocomplete="email"
          inputmode="email"
        />
        <p class="error-msg" id="emailError">Masukkan alamat email yang valid.</p>
      </div>

      <!-- Submit Button -->
      <button class="btn-primary" id="submitBtn" type="button">
        <span class="spinner" id="spinner"></span>
        <span class="btn-label">Kirim Kode OTP</span>
      </button>

      <!-- Back Link -->
      <a href="/login" class="back-link" id="backBtn">
        <span class="back-arrow">←</span>
        Kembali
      </a>
    </div>

    <script>
      const emailInput = document.getElementById('emailInput') as HTMLInputElement;
      const emailGroup = document.getElementById('emailGroup') as HTMLDivElement;
      const emailError = document.getElementById('emailError') as HTMLParagraphElement;
      const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
      const spinner = document.getElementById('spinner') as HTMLSpanElement;

      // 1. AMBIL DATA ROLE DARI URL SAAT HALAMAN INI DIMUAT
      const urlParams = new URLSearchParams(window.location.search);
      const currentRole = urlParams.get('role') || ''; // Mengambil nilai ?role=... dari halaman sebelumnya

      function validateEmail(email: string): boolean {
        return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.trim());
      }

      emailInput?.addEventListener('input', () => {
        if (emailGroup.classList.contains('has-error')) {
          if (validateEmail(emailInput.value)) {
            emailGroup.classList.remove('has-error');
          }
        }
      });

      submitBtn?.addEventListener('click', async () => {
        const email = emailInput.value.trim();

        if (!validateEmail(email)) {
          emailGroup.classList.add('has-error');
          emailInput.focus();
          return;
        }

        emailGroup.classList.remove('has-error');

        // Show loading state
        submitBtn.disabled = true;
        submitBtn.classList.add('loading');

        try {
          // API call simulation
          await new Promise((resolve) => setTimeout(resolve, 1500));
          console.log('OTP sent to:', email);

          // Simpan email ke sessionStorage
          sessionStorage.setItem('simapan_email', email);

          // 2. TERUSKAN KEDUA DATA (EMAIL DAN ROLE) KE HALAMAN VERIFIKASI
          window.location.href = `./verification?email=${encodeURIComponent(email)}&role=${encodeURIComponent(currentRole)}`;  
          
        } catch (err) {
          console.error('Failed to send OTP:', err);
        } finally {
          submitBtn.disabled = false;
          submitBtn.classList.remove('loading');
        }
      });

      // Allow Enter key to submit
      emailInput?.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter') submitBtn.click();
      });
    </script>
  </body>
</html>