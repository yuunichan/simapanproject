---
// SI MAPAN - Sistem ruMAh tangga dan kearsiPAN
// Step 3: Verifikasi Kode OTP
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SI MAPAN - Verifikasi OTP</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg-start: #2d3a4a;
        --bg-mid:   #3d5068;
        --bg-end:   #6b8fa8;
        --card-bg:  #ffffff;
        --text-primary:   #1a1a2e;
        --text-secondary: #6b7280;
        --text-label:     #374151;
        --border:         #e5e7eb;
        --border-focus:   #3b82f6;
        --accent-red:     #c0392b;
        --dot-active:     #3b82f6;
        --dot-inactive:   #d1d5db;
        --email-bg:       #eff6ff;
        --email-border:   #bfdbfe;
        --email-text:     #1d4ed8;
        --otp-border:     #d1d5db;
        --otp-border-focus: #3b82f6;
        --otp-filled-bg:  #ffffff;
        --btn-bg:         #3b82f6;
        --btn-hover:      #2563eb;
        --btn-text:       #ffffff;
        --resend-link:    #3b82f6;
        --shadow: 0 20px 60px rgba(0,0,0,0.25);
        --radius: 16px;
      }

      html, body { height: 100%; width: 100%; }

      body {
        font-family: 'DM Sans', sans-serif;
        background: linear-gradient(135deg, var(--bg-start) 0%, var(--bg-mid) 50%, var(--bg-end) 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        overflow: hidden;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background:
          radial-gradient(ellipse at 20% 80%, rgba(107,143,168,0.3) 0%, transparent 50%),
          radial-gradient(ellipse at 80% 20%, rgba(255,255,255,0.08) 0%, transparent 50%);
        pointer-events: none;
      }

      /* ── Card ── */
      .card {
        background: var(--card-bg);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 36px 36px 28px;
        width: 100%;
        max-width: 380px;
        animation: cardIn 0.6s cubic-bezier(0.22,1,0.36,1) both;
      }

      @keyframes cardIn {
        from { opacity: 0; transform: translateY(24px) scale(0.97); }
        to   { opacity: 1; transform: translateY(0)    scale(1); }
      }

      /* ── Logo ── */
      .logo-area {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 22px;
        animation: fadeUp 0.5s 0.05s both;
      }

      .logo-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 2.5px solid var(--accent-red);
        border-radius: 50px;
        padding: 5px 16px;
        margin-bottom: 5px;
      }

      .logo-text {
        font-size: 21px;
        font-weight: 700;
        letter-spacing: 0.04em;
        color: var(--accent-red);
      }

      .logo-tagline {
        font-size: 11px;
        color: var(--text-secondary);
        letter-spacing: 0.02em;
        text-align: center;
      }

      .logo-tagline strong { color: var(--accent-red); font-weight: 600; }

      /* ── Step Dots ── */
      .step-dots {
        display: flex;
        gap: 6px;
        justify-content: center;
        margin-bottom: 20px;
        animation: fadeUp 0.5s 0.1s both;
      }

      .dot {
        width: 22px;
        height: 6px;
        border-radius: 99px;
        background: var(--dot-inactive);
      }

      .dot.active {
        background: var(--dot-active);
        width: 26px;
      }

      /* ── Email chip ── */
      .email-chip {
        display: flex;
        align-items: center;
        gap: 8px;
        background: var(--email-bg);
        border: 1.5px solid var(--email-border);
        border-radius: 8px;
        padding: 9px 14px;
        margin-bottom: 16px;
        animation: fadeUp 0.5s 0.15s both;
      }

      .email-icon {
        flex-shrink: 0;
        color: var(--email-text);
        display: flex;
        align-items: center;
      }

      .email-icon svg {
        width: 15px;
        height: 15px;
      }

      .email-address {
        font-size: 13.5px;
        font-weight: 500;
        color: var(--email-text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      /* ── OTP hint ── */
      .otp-hint {
        text-align: center;
        font-size: 12.5px;
        color: var(--text-secondary);
        margin-bottom: 14px;
        animation: fadeUp 0.5s 0.2s both;
      }

      /* ── OTP Boxes ── */
      .otp-group {
        display: flex;
        gap: 8px;
        justify-content: center;
        margin-bottom: 20px;
        animation: fadeUp 0.5s 0.25s both;
      }

      .otp-box {
        width: 48px;
        height: 54px;
        border: 1.5px solid var(--otp-border);
        border-radius: 10px;
        text-align: center;
        font-family: 'DM Sans', sans-serif;
        font-size: 22px;
        font-weight: 700;
        color: var(--text-primary);
        background: var(--otp-filled-bg);
        outline: none;
        caret-color: var(--otp-border-focus);
        transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
        /* hide number spinners */
        -moz-appearance: textfield;
      }

      .otp-box::-webkit-outer-spin-button,
      .otp-box::-webkit-inner-spin-button { -webkit-appearance: none; }

      .otp-box:focus {
        border-color: var(--otp-border-focus);
        box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
        transform: scale(1.04);
      }

      .otp-box.filled {
        border-color: var(--otp-border-focus);
        background: #f0f7ff;
      }

      .otp-box.error {
        border-color: #ef4444;
        box-shadow: 0 0 0 3px rgba(239,68,68,0.12);
        animation: shake 0.35s ease;
      }

      @keyframes shake {
        0%,100% { transform: translateX(0); }
        20%      { transform: translateX(-5px); }
        40%      { transform: translateX(5px); }
        60%      { transform: translateX(-4px); }
        80%      { transform: translateX(4px); }
      }

      /* ── Primary Button ── */
      .btn-primary {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        padding: 12px 20px;
        background: var(--btn-bg);
        border: none;
        border-radius: 8px;
        font-family: 'DM Sans', sans-serif;
        font-size: 14.5px;
        font-weight: 600;
        color: var(--btn-text);
        cursor: pointer;
        transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
        margin-bottom: 14px;
        animation: fadeUp 0.5s 0.3s both;
        letter-spacing: 0.01em;
      }

      .btn-primary:hover:not(:disabled) {
        background: var(--btn-hover);
        box-shadow: 0 4px 16px rgba(59,130,246,0.4);
        transform: translateY(-1px);
      }

      .btn-primary:active:not(:disabled) {
        transform: translateY(0);
        box-shadow: none;
      }

      .btn-primary:disabled {
        opacity: 0.55;
        cursor: not-allowed;
      }

      .spinner {
        display: none;
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255,255,255,0.4);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
        margin-right: 8px;
        flex-shrink: 0;
      }

      @keyframes spin { to { transform: rotate(360deg); } }

      .btn-primary.loading .spinner { display: block; }

      /* ── Resend link ── */
      .resend-link {
        display: block;
        text-align: center;
        font-size: 12.5px;
        color: var(--resend-link);
        text-decoration: none;
        font-weight: 500;
        transition: opacity 0.2s;
        animation: fadeUp 0.5s 0.35s both;
      }

      .resend-link:hover { opacity: 0.75; text-decoration: underline; }

      .resend-link.disabled {
        color: var(--text-secondary);
        pointer-events: none;
        cursor: default;
      }

      .resend-timer {
        font-weight: 600;
        color: var(--text-primary);
      }

      /* ── Error banner ── */
      .error-banner {
        display: none;
        background: #fef2f2;
        border: 1.5px solid #fecaca;
        border-radius: 8px;
        padding: 9px 14px;
        font-size: 12.5px;
        color: #b91c1c;
        text-align: center;
        margin-bottom: 14px;
        animation: fadeUp 0.3s both;
      }

      .error-banner.visible { display: block; }

      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      @media (max-width: 420px) {
        .card { padding: 28px 20px 24px; }
        .otp-box { width: 42px; height: 48px; font-size: 20px; }
      }
    </style>
  </head>

  <body>
    <div class="card">

      <!-- Logo -->
      <div class="logo-area">
        <div class="logo-badge">
          <span class="logo-text">SI MAPAN</span>
        </div>
        <p class="logo-tagline">
          Sistem ru<strong>MAh</strong> tangga dan kearsi<strong>PAN</strong>
        </p>
      </div>

      <!-- Step dots: step 3 active -->
      <div class="step-dots">
        <div class="dot"></div>
        <div class="dot"></div>
        <div class="dot active"></div>
      </div>

      <!-- Email chip -->
      <div class="email-chip">
        <span class="email-icon">
          <svg viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
          </svg>
        </span>
        <span class="email-address" id="displayEmail">andi.prasetyo@bkn.go.id</span>
      </div>

      <!-- OTP hint -->
      <p class="otp-hint">Masukkan 6 digit kode OTP</p>

      <!-- Error banner -->
      <div class="error-banner" id="errorBanner">Kode OTP tidak valid. Silakan coba lagi.</div>

      <!-- OTP input boxes -->
      <div class="otp-group" id="otpGroup">
        <input class="otp-box" type="number" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="one-time-code" aria-label="Digit 1" />
        <input class="otp-box" type="number" maxlength="1" inputmode="numeric" pattern="[0-9]" aria-label="Digit 2" />
        <input class="otp-box" type="number" maxlength="1" inputmode="numeric" pattern="[0-9]" aria-label="Digit 3" />
        <input class="otp-box" type="number" maxlength="1" inputmode="numeric" pattern="[0-9]" aria-label="Digit 4" />
        <input class="otp-box" type="number" maxlength="1" inputmode="numeric" pattern="[0-9]" aria-label="Digit 5" />
        <input class="otp-box" type="number" maxlength="1" inputmode="numeric" pattern="[0-9]" aria-label="Digit 6" />
      </div>

      <!-- Verify button -->
      <button class="btn-primary" id="verifyBtn" type="button" disabled>
        <span class="spinner" id="spinner"></span>
        <span class="btn-label">Verifikasi &amp; Masuk</span>
      </button>

      <!-- Resend link -->
      <a href="#" class="resend-link disabled" id="resendLink">
        Tidak menerima kode?
        <span class="resend-timer" id="resendTimer">&nbsp;Kirim ulang</span>
      </a>

    </div>

    <script>
      // ── Populate email from URL param or sessionStorage ──
      const params = new URLSearchParams(window.location.search);
      const email  = params.get('email') || sessionStorage.getItem('simapan_email') || 'andi.prasetyo@bkn.go.id';
      (document.getElementById('displayEmail') as HTMLElement).textContent = email;

      // ── OTP box logic ──
      const boxes      = Array.from(document.querySelectorAll('.otp-box')) as HTMLInputElement[];
      const verifyBtn  = document.getElementById('verifyBtn')  as HTMLButtonElement;
      const errorBanner= document.getElementById('errorBanner') as HTMLDivElement;
      const resendLink = document.getElementById('resendLink') as HTMLAnchorElement;
      const resendTimer= document.getElementById('resendTimer') as HTMLSpanElement;

      function getOtp(): string {
        return boxes.map(b => b.value).join('');
      }

      function updateBtn() {
        verifyBtn.disabled = getOtp().length < 6;
      }

      function clearErrors() {
        boxes.forEach(b => b.classList.remove('error'));
        errorBanner.classList.remove('visible');
      }

      boxes.forEach((box, idx) => {
        // Enforce single digit
        box.addEventListener('input', () => {
          clearErrors();
          // Keep only last character typed
          if (box.value.length > 1) box.value = box.value.slice(-1);
          box.classList.toggle('filled', box.value !== '');
          if (box.value && idx < boxes.length - 1) boxes[idx + 1].focus();
          updateBtn();
        });

        box.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Backspace') {
            if (!box.value && idx > 0) {
              boxes[idx - 1].value = '';
              boxes[idx - 1].classList.remove('filled');
              boxes[idx - 1].focus();
            } else {
              box.value = '';
              box.classList.remove('filled');
            }
            updateBtn();
            e.preventDefault();
          }
          if (e.key === 'ArrowLeft'  && idx > 0)              { boxes[idx - 1].focus(); e.preventDefault(); }
          if (e.key === 'ArrowRight' && idx < boxes.length-1) { boxes[idx + 1].focus(); e.preventDefault(); }
          if (e.key === 'Enter' && getOtp().length === 6)      verifyBtn.click();
        });

        // Handle paste on any box
        box.addEventListener('paste', (e: ClipboardEvent) => {
          e.preventDefault();
          const pasted = e.clipboardData?.getData('text').replace(/\D/g,'').slice(0,6) ?? '';
          pasted.split('').forEach((ch, i) => {
            if (boxes[i]) {
              boxes[i].value = ch;
              boxes[i].classList.add('filled');
            }
          });
          const next = Math.min(pasted.length, boxes.length - 1);
          boxes[next].focus();
          updateBtn();
        });
      });

      // ── Verify button ──
      verifyBtn.addEventListener('click', async () => {
        const otp = getOtp();
        if (otp.length < 6) return;

        verifyBtn.disabled = true;
        verifyBtn.classList.add('loading');
        errorBanner.classList.remove('visible');

        try {
          // TODO: replace with real API call
          await new Promise(resolve => setTimeout(resolve, 1500));

          // Simulate success / failure (remove in production)
          const success = otp !== '000000';

          if (success) {
            console.log('OTP verified:', otp);
            window.location.href = '/dashboard';
            // window.location.href = '/dashboard';
          } else {
            boxes.forEach(b => b.classList.add('error'));
            errorBanner.classList.add('visible');
            boxes[0].focus();
          }
        } catch (err) {
          errorBanner.textContent = 'Terjadi kesalahan. Silakan coba lagi.';
          errorBanner.classList.add('visible');
        } finally {
          verifyBtn.disabled = false;
          verifyBtn.classList.remove('loading');
        }
      });

      // ── Resend countdown (60 s) ──
      let countdown = 60;

      function startCountdown() {
        resendLink.classList.add('disabled');
        resendTimer.textContent = ` (${countdown}s)`;

        const interval = setInterval(() => {
          countdown--;
          if (countdown <= 0) {
            clearInterval(interval);
            resendLink.classList.remove('disabled');
            resendTimer.textContent = ' Kirim ulang';
          } else {
            resendTimer.textContent = ` (${countdown}s)`;
          }
        }, 1000);
      }

      startCountdown();

      resendLink.addEventListener('click', async (e) => {
        e.preventDefault();
        if (resendLink.classList.contains('disabled')) return;
        countdown = 60;
        startCountdown();
        boxes.forEach(b => { b.value = ''; b.classList.remove('filled','error'); });
        updateBtn();
        errorBanner.classList.remove('visible');
        boxes[0].focus();

        // TODO: call resend OTP API
        console.log('Resend OTP to:', email);
      });
    </script>
  </body>
</html>