---
import simapanLogo from "../assets/Logo_simapan.png";

const { activePage = "dashboard" } = Astro.props;
---

<aside class="sidebar">
    <div class="sidebar-logo">
        <img
            class="logo-brand-img"
            src={simapanLogo.src}
            alt="Sistem Informasi Manajemen Aset dan Ruangan"
        />
    </div>

    <p class="admin-subtitle">Admin — BKN Pusat</p>

    <nav class="nav-section">
        <p class="nav-section-label">Administrasi</p>

        <!-- Dashboard Admin -->
        <a
            href="/admin/dashboard"
            class={`nav-item ${activePage === "dashboard" ? "active" : ""}`}
        >
            <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor">
                <path
                    d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM13 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2h-2zM13 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2h-2z"
                ></path>
            </svg>
            Dashboard Admin
        </a>

        <!-- Persetujuan -->
        <a
            href="/admin/persetujuan"
            class={`nav-item ${activePage === "persetujuan" ? "active" : ""}`}
        >
            <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor">
                <path
                    d="M4 3a1 1 0 00-1 1v12a1 1 0 001 1h8a1 1 0 001-1V8.414a1 1 0 00-.293-.707l-4.414-4.414A1 1 0 007.586 3H4z"
                ></path>
                <path
                    fill-rule="evenodd"
                    d="M13.78 9.97a.75.75 0 10-1.06-1.06L9.5 12.13l-1.22-1.22a.75.75 0 10-1.06 1.06l1.75 1.75a.75.75 0 001.06 0l3.75-3.75z"
                    clip-rule="evenodd"></path>
            </svg>
            Persetujuan
        </a>

        <!-- Laporan -->
        <a
            href="/admin/laporan"
            class={`nav-item ${activePage === "laporan" ? "active" : ""}`}
        >
            <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor">
                <path
                    d="M2 11a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1H3a1 1 0 01-1-1v-6zM8 7a1 1 0 011-1h2a1 1 0 011 1v10a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v13a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"
                ></path>
            </svg>
            Laporan
        </a>

        <!-- Manajemen User -->
        <a
            href="/admin/manajemen"
            class={`nav-item ${activePage === "manajemenuser" ? "active" : ""}`}
        >
            <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor">
                <path
                    d="M7 8a3 3 0 100-6 3 3 0 000 6zM14.5 9a2.5 2.5 0 100-5 2.5 2.5 0 000 5zM1.615 16.428a1.224 1.224 0 01-.569-1.175 6.002 6.002 0 0111.908 0c.058.467-.172.92-.57 1.174A9.953 9.953 0 017 18a9.953 9.953 0 01-5.385-1.572zM14.5 16h-.106c.07-.297.088-.605.048-.91a7.502 7.502 0 00-3.105-5.108A6.5 6.5 0 0118 15.5a.5.5 0 01-.5.5h-3z"
                ></path>
            </svg>
            Manajemen User
        </a>
    </nav>

    <div class="sidebar-footer">
        <div class="avatar">BS</div>
        <div class="user-info">
            <p class="user-name">Budi Santoso</p>
            <p class="user-role">Administrator</p>
        </div>
        <a href="/">
        <button class="logout-btn" title="Keluar">
            <svg width="15" height="15" viewBox="0 0 20 20" fill="currentColor">
                <path
                    fill-rule="evenodd"
                    d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z"
                    clip-rule="evenodd"></path>
            </svg>
        </button>
        </a>
    </div>
</aside>

<style>
    /* Tambahan kecil khusus subtitle admin, tidak mengubah class/CSS yang sudah ada */
    .admin-subtitle {
        font-size: 10.5px;
        color: var(--sidebar-label);
        text-align: center;
        padding: 8px 18px 0;
    }
</style>