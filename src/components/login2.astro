---
// SI MAPAN - Sistem ruMAh tangga dan kearsiPAN
// Step 2: Input Email Gmail & Kirim Kode OTP
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SI MAPAN - Verifikasi Email</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg-start: #2d3a4a;
        --bg-mid: #3d5068;
        --bg-end: #6b8fa8;
        --card-bg: #ffffff;
        --text-primary: #1a1a2e;
        --text-secondary: #6b7280;
        --text-label: #374151;
        --border: #e5e7eb;
        --border-focus: #3b82f6;
        --accent-red: #c0392b;
        --accent-blue: #2563eb;
        --btn-primary-bg: #3b82f6;
        --btn-primary-hover: #2563eb;
        --btn-primary-text: #ffffff;
        --dot-active: #3b82f6;
        --dot-inactive: #d1d5db;
        --back-link: #3b82f6;
        --shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
        --radius: 16px;
      }

      html, body {
        height: 100%;
        width: 100%;
      }

      body {
        font-family: 'DM Sans', sans-serif;
        background: linear-gradient(
          135deg,
          var(--bg-start) 0%,
          var(--bg-mid) 50%,
          var(--bg-end) 100%
        );
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        position: relative;
        overflow: hidden;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background:
          radial-gradient(ellipse at 20% 80%, rgba(107, 143, 168, 0.3) 0%, transparent 50%),
          radial-gradient(ellipse at 80% 20%, rgba(255, 255, 255, 0.08) 0%, transparent 50%);
        pointer-events: none;
      }

      /* Card */
      .card {
        background: var(--card-bg);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 40px 36px 32px;
        width: 100%;
        max-width: 400px;
        position: relative;
        animation: cardIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
      }

      @keyframes cardIn {
        from {
          opacity: 0;
          transform: translateY(24px) scale(0.97);
        }
        to {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }

      /* Logo */
      .logo-area {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 28px;
        animation: fadeUp 0.5s 0.1s both;
      }

      .logo-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 2.5px solid var(--accent-red);
        border-radius: 50px;
        padding: 6px 18px;
        margin-bottom: 6px;
      }

      .logo-text {
        font-family: 'DM Sans', sans-serif;
        font-size: 22px;
        font-weight: 700;
        letter-spacing: 0.04em;
        color: var(--accent-red);
      }

      .logo-tagline {
        font-size: 11.5px;
        color: var(--text-secondary);
        letter-spacing: 0.02em;
        text-align: center;
        line-height: 1.4;
      }

      .logo-tagline strong {
        color: var(--accent-red);
        font-weight: 600;
      }

      /* Step Dots */
      .step-dots {
        display: flex;
        gap: 6px;
        justify-content: center;
        margin-bottom: 24px;
        animation: fadeUp 0.5s 0.15s both;
      }

      .dot {
        width: 24px;
        height: 6px;
        border-radius: 99px;
        background: var(--dot-inactive);
        transition: background 0.3s;
      }

      .dot.active {
        background: var(--dot-active);
        width: 28px;
      }

      /* Form Group */
      .form-group {
        margin-bottom: 16px;
        animation: fadeUp 0.5s 0.2s both;
      }

      .form-label {
        display: block;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-label);
        margin-bottom: 8px;
      }

      .form-input {
        width: 100%;
        padding: 11px 14px;
        font-family: 'DM Sans', sans-serif;
        font-size: 14.5px;
        font-weight: 400;
        color: var(--text-primary);
        background: var(--card-bg);
        border: 1.5px solid var(--border);
        border-radius: 8px;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
      }

      .form-input::placeholder {
        color: #9ca3af;
      }

      .form-input:focus {
        border-color: var(--border-focus);
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
      }

      .form-input:hover:not(:focus) {
        border-color: #9ca3af;
      }

      /* Error message */
      .error-msg {
        display: none;
        font-size: 12px;
        color: #ef4444;
        margin-top: 6px;
      }

      .form-group.has-error .form-input {
        border-color: #ef4444;
        box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
      }

      .form-group.has-error .error-msg {
        display: block;
      }

      /* Primary Button */
      .btn-primary {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        padding: 12px 20px;
        background: var(--btn-primary-bg);
        border: none;
        border-radius: 8px;
        font-family: 'DM Sans', sans-serif;
        font-size: 14.5px;
        font-weight: 600;
        color: var(--btn-primary-text);
        cursor: pointer;
        transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
        margin-bottom: 14px;
        animation: fadeUp 0.5s 0.25s both;
        letter-spacing: 0.01em;
      }

      .btn-primary:hover {
        background: var(--btn-primary-hover);
        box-shadow: 0 4px 14px rgba(59, 130, 246, 0.4);
        transform: translateY(-1px);
      }

      .btn-primary:active {
        transform: translateY(0);
        box-shadow: none;
      }

      .btn-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
      }

      /* Loading spinner inside button */
      .spinner {
        display: none;
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255,255,255,0.4);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
        margin-right: 8px;
      }

      @keyframes spin {
        to { transform: rotate(360deg); }
      }

      .btn-primary.loading .spinner {
        display: block;
      }

      .btn-primary.loading .btn-label {
        opacity: 0.85;
      }

      /* Back Link */
      .back-link {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        font-size: 13px;
        color: var(--back-link);
        text-decoration: none;
        font-weight: 500;
        transition: opacity 0.2s;
        animation: fadeUp 0.5s 0.3s both;
      }

      .back-link:hover {
        opacity: 0.75;
        text-decoration: underline;
      }

      .back-arrow {
        font-size: 14px;
        line-height: 1;
      }

      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 480px) {
        .card {
          padding: 32px 24px 28px;
        }
      }
    </style>
  </head>

  <body>
    <div class="card">
      <!-- Logo -->
      <div class="logo-area">
        <div class="logo-badge">
          <span class="logo-text">SI MAPAN</span>
        </div>
        <p class="logo-tagline">
          Sistem ru<strong>MAh</strong> tangga dan kearsi<strong>PAN</strong>
        </p>
      </div>

      <!-- Step Dots: step 2 active -->
      <div class="step-dots">
        <div class="dot"></div>
        <div class="dot active"></div>
        <div class="dot"></div>
      </div>

      <!-- Email Input -->
      <div class="form-group" id="emailGroup">
        <label class="form-label" for="emailInput">Email Gmail BKN</label>
        <input
          type="email"
          id="emailInput"
          name="email"
          class="form-input"
          placeholder="andi.prasetyo@bkn.go.id"
          autocomplete="email"
          inputmode="email"
        />
        <p class="error-msg" id="emailError">Masukkan alamat email yang valid.</p>
      </div>

      <!-- Submit Button -->
      <button class="btn-primary" id="submitBtn" type="button">
        <span class="spinner" id="spinner"></span>
        <span class="btn-label">Kirim Kode OTP</span>
      </button>

      <!-- Back Link -->
      <a href="/login" class="back-link" id="backBtn">
        <span class="back-arrow">←</span>
        Kembali
      </a>
    </div>

    <script>
      const emailInput = document.getElementById('emailInput') as HTMLInputElement;
      const emailGroup = document.getElementById('emailGroup') as HTMLDivElement;
      const emailError = document.getElementById('emailError') as HTMLParagraphElement;
      const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
      const spinner = document.getElementById('spinner') as HTMLSpanElement;

      function validateEmail(email: string): boolean {
        return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.trim());
      }

      emailInput?.addEventListener('input', () => {
        if (emailGroup.classList.contains('has-error')) {
          if (validateEmail(emailInput.value)) {
            emailGroup.classList.remove('has-error');
          }
        }
      });

      submitBtn?.addEventListener('click', async () => {
        const email = emailInput.value.trim();

        if (!validateEmail(email)) {
          emailGroup.classList.add('has-error');
          emailInput.focus();
          return;
        }

        emailGroup.classList.remove('has-error');

        // Show loading state
        submitBtn.disabled = true;
        submitBtn.classList.add('loading');

        try {
          // TODO: Replace with actual API call to send OTP
          await new Promise((resolve) => setTimeout(resolve, 1500));
          console.log('OTP sent to:', email);

          // TODO: Navigate to OTP verification page
          // window.location.href = `/verify-otp?email=${encodeURIComponent(email)}`;
          // simpan email
          sessionStorage.setItem('simapan_email', email);

          // pindah ke halaman login3
          window.location.href = `/login3?email=${encodeURIComponent(email)}`;
          } catch (err) {
          console.error('Failed to send OTP:', err);
          } finally {
          submitBtn.disabled = false;
          submitBtn.classList.remove('loading');
          }
      });

      // Allow Enter key to submit
      emailInput?.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter') submitBtn.click();
      });
    </script>
  </body>
</html>